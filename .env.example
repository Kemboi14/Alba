# =============================================================================
# Alba Capital ERP System — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in every value before running the server.
# NEVER commit .env to version control.
# =============================================================================


# =============================================================================
# DJANGO CORE
# =============================================================================

SECRET_KEY=your-secret-key-here-change-in-production-use-at-least-50-chars

DEBUG=True

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=localhost,127.0.0.1


# =============================================================================
# DATABASE — PostgreSQL
# =============================================================================

DB_NAME=alba_capital
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432


# =============================================================================
# SECURITY (set both to True in production behind HTTPS)
# =============================================================================

SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False


# =============================================================================
# EMAIL
# =============================================================================

# Use console backend for local development; switch to SMTP in production
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@albacapital.co.ke
EMAIL_HOST_PASSWORD=your-email-app-password
DEFAULT_FROM_EMAIL=Alba Capital <noreply@albacapital.co.ke>


# =============================================================================
# ODOO INTEGRATION
# =============================================================================
# These variables connect the Django portal to the Odoo Enterprise backend.
# Leave ODOO_URL blank during initial development — the portal will skip
# Odoo sync calls gracefully when the URL is not set.
# =============================================================================

# Base URL of your Odoo instance (no trailing slash)
# Example: https://odoo.albacapital.co.ke
ODOO_URL=

# API key value — copy from Odoo: Alba Integration → API Keys → Key field
ODOO_API_KEY=

# Shared HMAC-SHA256 secret for verifying INBOUND webhooks from Odoo.
# Copy from Odoo: Alba Integration → API Keys → Webhook Secret field.
# Must be at least 32 random characters.  Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
ODOO_WEBHOOK_SECRET=

# HTTP request timeout in seconds (default: 30)
ODOO_TIMEOUT=30

# Max number of automatic retries on transient errors (default: 3)
ODOO_MAX_RETRIES=3

# Back-off base in seconds between retries — doubles each attempt (default: 2)
ODOO_RETRY_BACKOFF=2


# =============================================================================
# M-PESA — SAFARICOM DARAJA API
# =============================================================================
# The Django portal operates in PROXY mode by default: all Daraja API calls
# are routed through Odoo, which manages credentials, token caching, and
# the transaction audit log.  Set MPESA_STANDALONE=False (the default).
#
# For local development WITHOUT Odoo, set MPESA_STANDALONE=True and fill in
# the standalone credentials below.  Do NOT use standalone mode in production.
# =============================================================================

# Proxy mode (recommended for production)
# When False, all STK Push calls go through Odoo's REST API.
MPESA_STANDALONE=False

# Odoo endpoint to trigger an STK Push (proxy mode only)
MPESA_STK_ENDPOINT=/alba/api/v1/mpesa/stk-push

# Odoo endpoint to query STK Push status (proxy mode only)
MPESA_STK_QUERY_ENDPOINT=/alba/api/v1/mpesa/stk-status

# ---------------------------------------------------------------------------
# Standalone mode credentials (only needed when MPESA_STANDALONE=True)
# ---------------------------------------------------------------------------

# Daraja Consumer Key — from https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY=

# Daraja Consumer Secret
MPESA_CONSUMER_SECRET=

# M-Pesa Business Short Code (Paybill number), e.g. 174379 (sandbox default)
MPESA_SHORTCODE=

# Optional: Till Number for Buy Goods transactions
MPESA_TILL_NUMBER=

# Lipa Na M-Pesa Passkey (required for STK Push)
MPESA_PASSKEY=

# Account type: paybill | till
MPESA_ACCOUNT_TYPE=paybill

# Public HTTPS base URL of this Django instance, used to build callback URLs.
# Safaricom POSTs callbacks to <MPESA_CALLBACK_BASE_URL>/alba/mpesa/stk/callback
# Must be publicly reachable from the internet (not localhost).
MPESA_CALLBACK_BASE_URL=

# Set to True to use the Daraja sandbox environment
MPESA_SANDBOX=True

# Optional: Comma-separated list of Safaricom IP addresses allowed to send
# inbound C2B callbacks.  Leave blank to accept from any IP (less secure).
# Safaricom production IP ranges: 196.201.214.200/24,196.201.214.206/24
MPESA_ALLOWED_IPS=


# =============================================================================
# REDIS / CELERY  (optional — for background task processing)
# =============================================================================
# Uncomment and configure when using Celery for async webhook processing,
# scheduled sync jobs, or notification queuing.
# =============================================================================

# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1


# =============================================================================
# CACHE  (optional — used for portfolio stats and integration health caching)
# =============================================================================
# Default: in-memory (LocMemCache) — fine for single-process development.
# For production / multi-process use Redis:
# =============================================================================

# CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
# CACHE_LOCATION=redis://localhost:6379/2


# =============================================================================
# LOGGING  (optional overrides)
# =============================================================================

# Log level for the Django portal (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# Set to True to log all outgoing Odoo API requests at DEBUG level
ODOO_DEBUG_REQUESTS=False
