<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<template id="report_par_template">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="doc">
            <t t-set="data" t-value="doc.get_par_data()"/>
            <t t-set="sym"  t-value="data['currency'].symbol"/>
            <t t-call="web.external_layout">
                <div class="page">

                    <!-- ── Title ──────────────────────────────────────────── -->
                    <div class="row mb-3">
                        <div class="col-8">
                            <h2 class="text-primary"><strong>PORTFOLIO AT RISK (PAR) REPORT</strong></h2>
                            <h5 class="text-muted">
                                As of: <strong><t t-esc="data['as_of_date']"/></strong>
                            </h5>
                        </div>
                        <div class="col-4 text-end text-muted" style="font-size:11px;">
                            <t t-esc="data['company'].name"/><br/>
                            Generated: <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d %b %Y %H:%M')"/>
                        </div>
                    </div>
                    <hr/>

                    <!-- ── KPI Summary ────────────────────────────────────── -->
                    <div class="row mb-4">
                        <div class="col-3 text-center border p-2 me-2 rounded">
                            <div class="text-muted" style="font-size:11px;">TOTAL PORTFOLIO</div>
                            <div style="font-size:16px; font-weight:bold;">
                                <t t-esc="sym"/> <t t-esc="'{:,.0f}'.format(data['total_portfolio'])"/>
                            </div>
                            <div class="text-muted" style="font-size:11px;"><t t-esc="data['total_loans']"/> loans</div>
                        </div>
                        <div class="col-3 text-center border p-2 me-2 rounded">
                            <div class="text-muted" style="font-size:11px;">AT-RISK PORTFOLIO</div>
                            <div style="font-size:16px; font-weight:bold; color:#c0392b;">
                                <t t-esc="sym"/> <t t-esc="'{:,.0f}'.format(data['total_at_risk'])"/>
                            </div>
                            <div class="text-muted" style="font-size:11px;">
                                PAR: <t t-esc="'{:.1f}'.format(data['overall_par_pct'])"/>%
                            </div>
                        </div>
                        <div class="col-3 text-center border p-2 rounded">
                            <div class="text-muted" style="font-size:11px;">NPL BALANCE</div>
                            <div style="font-size:16px; font-weight:bold; color:#8e44ad;">
                                <t t-esc="sym"/> <t t-esc="'{:,.0f}'.format(data['npl_balance'])"/>
                            </div>
                            <div class="text-muted" style="font-size:11px;">
                                NPL Ratio: <t t-esc="'{:.1f}'.format(data['npl_pct'])"/>%
                                &#160;(<t t-esc="data['npl_count']"/> loans)
                            </div>
                        </div>
                    </div>

                    <!-- ── PAR Bucket Table ───────────────────────────────── -->
                    <table class="table table-sm table-bordered table-striped">
                        <thead class="table-dark">
                            <tr>
                                <th>Arrears Bucket</th>
                                <th class="text-end">No. of Loans</th>
                                <th class="text-end">Outstanding Balance</th>
                                <th class="text-end">Arrears Amount</th>
                                <th class="text-end">% of Portfolio</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="data['buckets']" t-as="bucket">
                                <tr>
                                    <td><strong><t t-esc="bucket['label']"/></strong></td>
                                    <td class="text-end"><t t-esc="bucket['count']"/></td>
                                    <td class="text-end">
                                        <t t-esc="sym"/>
                                        <t t-esc="'{:,.2f}'.format(bucket['outstanding_balance'])"/>
                                    </td>
                                    <td class="text-end">
                                        <t t-if="bucket['arrears_amount']">
                                            <t t-esc="sym"/>
                                            <t t-esc="'{:,.2f}'.format(bucket['arrears_amount'])"/>
                                        </t>
                                        <t t-else="">—</t>
                                    </td>
                                    <td class="text-end">
                                        <t t-esc="'{:.1f}'.format(bucket['par_pct'])"/>%
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                        <tfoot class="table-secondary fw-bold">
                            <tr>
                                <td><strong>TOTAL</strong></td>
                                <td class="text-end"><t t-esc="data['total_loans']"/></td>
                                <td class="text-end">
                                    <t t-esc="sym"/>
                                    <t t-esc="'{:,.2f}'.format(data['total_portfolio'])"/>
                                </td>
                                <td class="text-end">
                                    <t t-esc="sym"/>
                                    <t t-esc="'{:,.2f}'.format(data['total_at_risk'])"/>
                                </td>
                                <td class="text-end">
                                    <t t-esc="'{:.1f}'.format(data['overall_par_pct'])"/>%
                                </td>
                            </tr>
                        </tfoot>
                    </table>

                    <!-- ── Footer note ───────────────────────────────────── -->
                    <p class="text-muted mt-3" style="font-size:10px;">
                        * PAR is calculated as the outstanding balance of loans with at least one
                        instalment overdue by more than the specified number of days, divided by
                        the total gross loan portfolio. NPL loans are those classified as
                        Non-Performing (90+ days in arrears).
                    </p>

                </div>
            </t>
        </t>
    </t>
</template>

</data>
</odoo>
