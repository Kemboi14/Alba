<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- ================================================================
             Alba Capital Default Approval Limits
             Based on Requirements Questionnaire Section B
             ================================================================ -->
        
        <!-- Loan Application Approvals -->
        <record id="approval_limit_loan_officer" model="alba.approval.limit">
            <field name="name">Loan Application - Officer Level (0-100K)</field>
            <field name="process_type">loan_application</field>
            <field name="min_amount">0</field>
            <field name="max_amount">100000</field>
            <field name="approver_group_id" ref="alba_loans.group_operations_manager"/>
            <field name="require_second_approval">False</field>
            <field name="active">True</field>
        </record>
        
        <record id="approval_limit_loan_manager" model="alba.approval.limit">
            <field name="name">Loan Application - Manager Level (100K-500K)</field>
            <field name="process_type">loan_application</field>
            <field name="min_amount">100001</field>
            <field name="max_amount">500000</field>
            <field name="approver_group_id" ref="alba_loans.group_operations_manager"/>
            <field name="require_second_approval">False</field>
            <field name="active">True</field>
        </record>
        
        <record id="approval_limit_loan_director" model="alba.approval.limit">
            <field name="name">Loan Application - Director Level (500K+)</field>
            <field name="process_type">loan_application</field>
            <field name="min_amount">500001</field>
            <field name="max_amount">999999999</field>
            <field name="approver_group_id" ref="alba_loans.group_director"/>
            <field name="require_second_approval">True</field>
            <field name="second_approver_group_id" ref="alba_loans.group_director"/>
            <field name="active">True</field>
        </record>
        
        <!-- Loan Disbursement Approvals -->
        <record id="approval_limit_disburse_standard" model="alba.approval.limit">
            <field name="name">Loan Disbursement - Standard (0-500K)</field>
            <field name="process_type">loan_disbursement</field>
            <field name="min_amount">0</field>
            <field name="max_amount">500000</field>
            <field name="approver_group_id" ref="alba_loans.group_operations_manager"/>
            <field name="require_second_approval">False</field>
            <field name="active">True</field>
        </record>
        
        <record id="approval_limit_disburse_large" model="alba.approval.limit">
            <field name="name">Loan Disbursement - Large (500K+)</field>
            <field name="process_type">loan_disbursement</field>
            <field name="min_amount">500001</field>
            <field name="max_amount">999999999</field>
            <field name="approver_group_id" ref="alba_loans.group_director"/>
            <field name="require_second_approval">True</field>
            <field name="second_approver_group_id" ref="alba_loans.group_finance_admin"/>
            <field name="active">True</field>
        </record>
        
        <!-- Write-Off Approvals - Director Only -->
        <record id="approval_limit_writeoff" model="alba.approval.limit">
            <field name="name">Loan Write-Off - Director Only</field>
            <field name="process_type">write_off</field>
            <field name="min_amount">0</field>
            <field name="max_amount">999999999</field>
            <field name="approver_group_id" ref="alba_loans.group_director"/>
            <field name="require_second_approval">False</field>
            <field name="active">True</field>
        </record>
        
        <!-- Journal Entry Approvals -->
        <record id="approval_limit_journal_standard" model="alba.approval.limit">
            <field name="name">Journal Entry - Standard (0-50K)</field>
            <field name="process_type">journal_entry</field>
            <field name="min_amount">0</field>
            <field name="max_amount">50000</field>
            <field name="approver_group_id" ref="alba_loans.group_finance_admin"/>
            <field name="require_second_approval">False</field>
            <field name="active">True</field>
        </record>
        
        <record id="approval_limit_journal_large" model="alba.approval.limit">
            <field name="name">Journal Entry - Large (50K+)</field>
            <field name="process_type">journal_entry</field>
            <field name="min_amount">50001</field>
            <field name="max_amount">999999999</field>
            <field name="approver_group_id" ref="alba_loans.group_director"/>
            <field name="require_second_approval">False</field>
            <field name="active">True</field>
        </record>
        
        <!-- Investor Withdrawal Approvals -->
        <record id="approval_limit_investor_withdrawal" model="alba.approval.limit">
            <field name="name">Investor Withdrawal - Operations Manager</field>
            <field name="process_type">investor_withdrawal</field>
            <field name="min_amount">0</field>
            <field name="max_amount">999999999</field>
            <field name="approver_group_id" ref="alba_loans.group_operations_manager"/>
            <field name="require_second_approval">False</field>
            <field name="active">True</field>
        </record>
        
        <!-- Restructure Approvals -->
        <record id="approval_limit_restructure" model="alba.approval.limit">
            <field name="name">Loan Restructure - Operations Manager</field>
            <field name="process_type">restructure</field>
            <field name="min_amount">0</field>
            <field name="max_amount">999999999</field>
            <field name="approver_group_id" ref="alba_loans.group_operations_manager"/>
            <field name="require_second_approval">False</field>
            <field name="active">True</field>
        </record>
        
        <!-- ================================================================
             Segregation of Duties Rules
             ================================================================ -->
        
        <!-- SoD: Loan Process -->
        <record id="sod_rule_loan" model="alba.segregation.of.duties">
            <field name="name">SoD: Loan Submission vs Approval</field>
            <field name="process_type">loan</field>
            <field name="creator_group_id" ref="alba_loans.group_relationship_officer"/>
            <field name="approver_group_id" ref="alba_loans.group_operations_manager"/>
            <field name="enforce_different_user">True</field>
            <field name="active">True</field>
        </record>
        
        <!-- SoD: Journal Entry -->
        <record id="sod_rule_journal" model="alba.segregation.of.duties">
            <field name="name">SoD: Journal Entry Preparation vs Approval</field>
            <field name="process_type">journal</field>
            <field name="creator_group_id" ref="alba_loans.group_finance_officer"/>
            <field name="approver_group_id" ref="alba_loans.group_finance_admin"/>
            <field name="enforce_different_user">True</field>
            <field name="active">True</field>
        </record>
        
        <!-- SoD: Investor Withdrawal -->
        <record id="sod_rule_investor" model="alba.segregation.of.duties">
            <field name="name">SoD: Investor Withdrawal Request vs Approval</field>
            <field name="process_type">investor</field>
            <field name="creator_group_id" ref="alba_loans.group_investor_officer"/>
            <field name="approver_group_id" ref="alba_loans.group_operations_manager"/>
            <field name="enforce_different_user">True</field>
            <field name="active">True</field>
        </record>
        
    </data>
</odoo>
