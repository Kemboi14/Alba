<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_loan_refinance_tree" model="ir.ui.view">
        <field name="name">alba.loan.refinance.tree</field>
        <field name="model">alba.loan.refinance</field>
        <field name="arch" type="xml">
            <list decoration-muted="state=='rejected'" decoration-success="state=='completed'" decoration-info="state=='quoted'">
                <field name="name"/>
                <field name="original_loan_id"/>
                <field name="customer_id"/>
                <field name="new_product_id"/>
                <field name="original_outstanding"/>
                <field name="new_principal"/>
                <field name="monthly_savings"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_loan_refinance_form" model="ir.ui.view">
        <field name="name">alba.loan.refinance.form</field>
        <field name="model">alba.loan.refinance</field>
        <field name="arch" type="xml">
            <form string="Loan Refinance">
                <header>
                    <button name="action_generate_quote" string="Generate Quote" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_customer_accept" string="Customer Accept" type="object" class="oe_highlight" invisible="state != 'quoted'"/>
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state != 'customer_accepted'"/>
                    <button name="action_settle_original_loan" string="Settle Original" type="object" class="oe_highlight" invisible="state != 'approved'"/>
                    <button name="action_create_new_loan" string="Create New Loan" type="object" class="oe_highlight" invisible="state != 'settled'"/>
                    <button name="action_complete" string="Complete" type="object" class="oe_highlight" invisible="state != 'disbursed'"/>
                    <button name="action_reject" string="Reject" type="object" invisible="state not in ('draft', 'quoted')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,quoted,approved,settled,disbursed,completed"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group>
                        <group string="Original Loan">
                            <field name="original_loan_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                            <field name="customer_id" readonly="1"/>
                            <field name="original_product_id" readonly="1"/>
                            <field name="original_outstanding" readonly="1"/>
                            <field name="original_rate" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="New Terms">
                            <field name="new_product_id" readonly="state != 'draft'"/>
                            <field name="new_principal" readonly="state != 'draft'"/>
                            <field name="new_interest_rate" readonly="state != 'draft'"/>
                            <field name="new_tenure_months" readonly="state != 'draft'"/>
                            <field name="new_repayment_frequency" readonly="state != 'draft'"/>
                            <field name="new_emi" readonly="1"/>
                        </group>
                    </group>
                    <group string="Settlement">
                        <group>
                            <field name="settlement_amount" readonly="1"/>
                            <field name="refinance_fee_rate" readonly="state != 'draft'"/>
                            <field name="refinance_fee_amount" readonly="1"/>
                        </group>
                        <group>
                            <field name="cashback_to_customer" readonly="1"/>
                            <field name="customer_to_pay" readonly="1"/>
                            <field name="monthly_savings" readonly="1"/>
                        </group>
                    </group>
                    <group string="Links" invisible="not new_loan_id">
                        <field name="new_loan_application_id" readonly="1"/>
                        <field name="new_loan_id" readonly="1"/>
                    </group>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_loan_refinance" model="ir.actions.act_window">
        <field name="name">Refinances</field>
        <field name="res_model">alba.loan.refinance</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_loan_refinance" name="Refinances" parent="menu_alba_loans_root_active" action="action_loan_refinance" sequence="34"/>
</odoo>
