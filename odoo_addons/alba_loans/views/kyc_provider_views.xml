<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_alba_kyc_provider_list" model="ir.ui.view">
            <field name="name">alba.kyc.provider.list</field>
            <field name="model">alba.kyc.provider</field>
            <field name="arch" type="xml">
                <list string="KYC Providers">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="provider_type"/>
                    <field name="is_active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <record id="view_alba_kyc_provider_form" model="ir.ui.view">
            <field name="name">alba.kyc.provider.form</field>
            <field name="model">alba.kyc.provider</field>
            <field name="arch" type="xml">
                <form string="KYC Provider">
                    <header>
                        <button name="action_test_connection" string="Test Connection" type="object" class="btn-secondary"/>
                    </header>
                    <sheet>
                        <widget name="web_ribbon" title="Active" bg_color="bg-success" invisible="not is_active"/>
                        <div class="oe_title">
                            <label for="name" string="Provider Name"/>
                            <h1><field name="name" placeholder="e.g. Smile Identity API"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="provider_type"/>
                                <field name="is_active"/>
                            </group>
                            <group string="API Credentials" invisible="provider_type == 'sandbox'">
                                <field name="api_base_url"/>
                                <field name="api_key" password="True"/>
                                <field name="api_secret" password="True"/>
                            </group>
                        </group>
                        
                        <div class="alert alert-info mt-3" role="alert" invisible="provider_type != 'sandbox'">
                            <h4 class="alert-heading">Sandbox / Mock Provider Enabled</h4>
                            <p>This mode is for testing. It simulates KYC verification responses based on the ID number:</p>
                            <ul>
                                <li><strong>Starts with 99:</strong> Rejected (Fraud watchlist)</li>
                                <li><strong>Starts with 88:</strong> Needs Manual Review</li>
                                <li><strong>All others:</strong> Verified Successfully</li>
                            </ul>
                        </div>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="action_alba_kyc_provider" model="ir.actions.act_window">
            <field name="name">KYC Identity Providers</field>
            <field name="res_model">alba.kyc.provider</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Menu Item -->
        <menuitem id="menu_alba_kyc_provider"
                  name="KYC Providers"
                  parent="alba_loans.menu_alba_loans_config"
                  action="action_alba_kyc_provider"
                  sequence="30"
                  groups="alba_loans.group_director"/>
    </data>
</odoo>
