<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ================================================================
             alba.loan.document — List View (Simplified)
             ================================================================ -->
        <record id="view_alba_loan_document_list" model="ir.ui.view">
            <field name="name">alba.loan.document.list</field>
            <field name="model">alba.loan.document</field>
            <field name="arch" type="xml">
                <list string="Documents" decoration-info="state == 'draft'" decoration-success="state == 'verified'" decoration-danger="state == 'rejected'">
                    <field name="name"/>
                    <field name="document_type"/>
                    <field name="partner_id" string="Owner" column_invisible="context.get('hide_partner')"/>
                    <field name="attachment_id" widget="many2one_binary" string="File"/>
                    <field name="uploaded_by" optional="hide"/>
                    <field name="create_date" string="Uploaded On" widget="date"/>
                    <field name="state" widget="badge" 
                           decoration-success="state == 'verified'" 
                           decoration-warning="state == 'draft'" 
                           decoration-danger="state == 'rejected'"/>
                    <button name="action_verify" string="Verify" type="object" icon="fa-check-circle" class="text-success" invisible="state == 'verified'"/>
                    <button name="action_reset_to_draft" string="Re-upload" type="object" icon="fa-undo" invisible="state == 'draft'"/>
                </list>
            </field>
        </record>

        <!-- ================================================================
             alba.loan.document — Kanban View (Premium Card Design)
             ================================================================ -->
        <record id="view_alba_loan_document_kanban" model="ir.ui.view">
            <field name="name">alba.loan.document.kanban</field>
            <field name="model">alba.loan.document</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile">
                    <field name="id"/>
                    <field name="name"/>
                    <field name="document_type"/>
                    <field name="state"/>
                    <field name="attachment_id"/>
                    <field name="mimetype"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_global_click d-flex align-items-center p-2 border-bottom">
                                <div class="o_kanban_image me-3">
                                    <t t-if="['image/png', 'image/jpeg', 'image/gif'].includes(record.mimetype.raw_value)">
                                        <img t-att-src="kanban_image('ir.attachment', 'datas', record.attachment_id.raw_value)" 
                                             class="o_image_64_max rounded shadow-sm" alt="Document"/>
                                    </t>
                                    <t t-else="">
                                        <div class="o_image_64_max d-flex align-items-center justify-content-center bg-light rounded shadow-sm text-primary">
                                            <i class="fa fa-file-text-o fa-2x" title="Document"/>
                                        </div>
                                    </t>
                                </div>
                                <div class="o_kanban_details flex-grow-1">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <strong class="o_kanban_record_title"><field name="name"/></strong>
                                        <field name="state" widget="label_selection" options="{'classes': {'draft': 'info', 'verified': 'success', 'rejected': 'danger'}}"/>
                                    </div>
                                    <div class="text-muted small">
                                        <field name="document_type"/>
                                    </div>
                                    <div class="mt-2 d-flex justify-content-end">
                                        <button name="action_verify" string="Verify" type="object" 
                                                class="btn btn-sm btn-outline-success py-0 px-2 me-1" 
                                                invisible="state == 'verified'">
                                            <i class="fa fa-check me-1"/> Verify
                                        </button>
                                        <field name="attachment_id" widget="many2one_binary" string="Download"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- ================================================================
             alba.loan.document — Form View
             ================================================================ -->
        <record id="view_alba_loan_document_form" model="ir.ui.view">
            <field name="name">alba.loan.document.form</field>
            <field name="model">alba.loan.document</field>
            <field name="arch" type="xml">
                <form string="Document">
                    <header>
                        <button name="action_verify" string="Verify" type="object" class="btn-primary" invisible="state == 'verified'"/>
                        <button name="action_reset_to_draft" string="Reset to Draft" type="object" invisible="state == 'draft'"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="document_type"/>
                                <field name="partner_id"/>
                            </group>
                            <group>
                                <field name="attachment_id" widget="many2one_binary"/>
                                <field name="uploaded_by"/>
                                <field name="create_date" string="Uploaded On" readonly="1"/>
                            </group>
                        </group>
                        <group string="Verification Details" invisible="state == 'draft'">
                            <field name="verified_by"/>
                            <field name="verified_date"/>
                            <field name="rejection_reason" invisible="state != 'rejected'"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>
