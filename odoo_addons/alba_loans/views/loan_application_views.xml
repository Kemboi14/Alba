<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ================================================================
             alba.loan.application — Form View
             ================================================================ -->
        <record id="view_alba_loan_application_form" model="ir.ui.view">
            <field name="name">alba.loan.application.form</field>
            <field name="model">alba.loan.application</field>
            <field name="arch" type="xml">
                <form string="Loan Application">
                    <header>
                        <!-- Workflow Buttons -->
                        <button name="action_submit"
                                string="Submit Application"
                                type="object"
                                class="btn-primary"
                                invisible="not can_submit"/>
                        <button name="action_under_review"
                                string="Start Review"
                                type="object"
                                class="btn-primary"
                                invisible="not can_review"
                                groups="alba_loans.group_loan_officer"/>
                        <button name="action_credit_analysis"
                                string="Send to Credit Analysis"
                                type="object"
                                class="btn-primary"
                                invisible="not can_credit_analysis"
                                groups="alba_loans.group_loan_officer"/>
                        <button name="action_pending_approval"
                                string="Forward for Approval"
                                type="object"
                                class="btn-primary"
                                invisible="not can_pending_approval"
                                groups="alba_loans.group_loan_officer"/>
                        <button name="action_approve"
                                string="Approve"
                                type="object"
                                class="btn-success"
                                invisible="not can_approve"
                                groups="alba_loans.group_loan_manager"/>
                        <button name="action_employer_verification"
                                string="Send for Employer Verification"
                                type="object"
                                class="btn-primary"
                                invisible="not can_employer_verify"
                                groups="alba_loans.group_loan_officer"/>
                        <button name="action_guarantor_confirmation"
                                string="Send for Guarantor Confirmation"
                                type="object"
                                class="btn-primary"
                                invisible="not can_guarantor_confirm"
                                groups="alba_loans.group_loan_officer"/>
                        <button name="action_open_disburse_wizard"
                                string="Disburse Loan"
                                type="object"
                                class="btn-success"
                                invisible="not can_disburse"
                                groups="alba_loans.group_loan_manager"/>
                        <button name="action_reject"
                                string="Reject"
                                type="object"
                                class="btn-danger"
                                invisible="not can_reject"
                                groups="alba_loans.group_loan_officer"/>
                        <button name="action_cancel"
                                string="Cancel"
                                type="object"
                                class="btn-secondary"
                                invisible="not can_cancel"/>

                        <!-- Status Bar -->
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,submitted,under_review,credit_analysis,pending_approval,approved,disbursed"/>
                    </header>

                    <sheet>
                        <!-- Smart Buttons -->
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_loan"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-money"
                                    invisible="loan_count == 0">
                                <field name="loan_count" widget="statinfo" string="Loan"/>
                            </button>
                        </div>

                        <!-- Rejection / cancellation alert banners -->
                        <div class="alert alert-danger" role="alert"
                             invisible="state != 'rejected'">
                            <strong>Rejected:</strong>
                            <field name="rejection_reason" readonly="1" nolabel="1"/>
                        </div>
                        <div class="alert alert-warning" role="alert"
                             invisible="state != 'cancelled'">
                            <strong>Cancelled:</strong>
                            <field name="cancellation_reason" readonly="1" nolabel="1"/>
                        </div>

                        <div class="oe_title">
                            <label for="application_number" string="Application"/>
                            <h1>
                                <field name="application_number" readonly="1"/>
                            </h1>
                        </div>

                        <group>
                            <group string="Applicant">
                                <field name="customer_id"
                                       options="{'no_create': False}"
                                       readonly="state != 'draft'"/>
                                <field name="partner_id" readonly="1"/>
                                <field name="company_id"
                                       groups="base.group_multi_company"
                                       readonly="state != 'draft'"/>
                            </group>
                            <group string="Loan Request">
                                <field name="loan_product_id"
                                       readonly="state != 'draft'"/>
                                <field name="currency_id" invisible="1"/>
                                <field name="requested_amount"
                                       readonly="state != 'draft'"/>
                                <field name="approved_amount"
                                       readonly="state not in ('pending_approval','approved','employer_verification','guarantor_confirmation')"
                                       groups="alba_loans.group_loan_manager"/>
                                <field name="tenure_months"
                                       readonly="state != 'draft'"/>
                                <field name="repayment_frequency"
                                       readonly="state != 'draft'"/>
                            </group>
                        </group>

                        <!-- Estimated totals info box -->
                        <group string="Indicative Loan Totals" col="3">
                            <field name="estimated_total_interest" readonly="1"/>
                            <field name="estimated_total_fees"     readonly="1"/>
                            <field name="estimated_total_repayable" readonly="1"/>
                        </group>

                        <notebook>

                            <!-- ── Loan Purpose ───────────────────────────── -->
                            <page string="Loan Purpose" name="purpose">
                                <field name="purpose"
                                       nolabel="1"
                                       readonly="state != 'draft'"
                                       placeholder="Describe the purpose of this loan application…"/>
                            </page>

                            <!-- ── Approval Details ───────────────────────── -->
                            <page string="Approval Details" name="approval"
                                  invisible="state not in ('approved','employer_verification','guarantor_confirmation','disbursed','rejected')">
                                <group>
                                    <group string="Approval">
                                        <field name="approved_by" readonly="1"/>
                                        <field name="approved_date" readonly="1"/>
                                        <field name="conditions_of_approval"
                                               readonly="state not in ('pending_approval','approved')"/>
                                    </group>
                                    <group string="Review">
                                        <field name="reviewed_by" readonly="1"/>
                                        <field name="reviewed_date" readonly="1"/>
                                        <field name="disbursed_by" readonly="1"/>
                                        <field name="disbursed_date" readonly="1"/>
                                    </group>
                                </group>
                                <group invisible="state != 'rejected'"
                                       string="Rejection">
                                    <field name="rejection_reason"
                                           readonly="state == 'rejected'"/>
                                </group>
                            </page>

                            <!-- ── Stage Timeline ─────────────────────────── -->
                            <page string="Stage Timeline" name="timeline">
                                <group col="2">
                                    <group string="Stage Dates">
                                        <field name="submitted_date"             readonly="1"/>
                                        <field name="reviewed_date"              readonly="1"/>
                                        <field name="credit_analysis_date"       readonly="1"/>
                                        <field name="pending_approval_date"      readonly="1"/>
                                        <field name="approved_date"              readonly="1"/>
                                        <field name="employer_verification_date" readonly="1"/>
                                        <field name="guarantor_confirmation_date" readonly="1"/>
                                        <field name="disbursed_date"             readonly="1"/>
                                        <field name="rejected_date"              readonly="1"/>
                                        <field name="cancelled_date"             readonly="1"/>
                                    </group>
                                </group>
                            </page>

                            <!-- ── Documents ─────────────────────────────── -->
                            <page string="Documents" name="documents">
                                <field name="loan_document_ids" nolabel="1">
                                    <list string="Documents" editable="bottom">
                                        <field name="name" string="Document Name"/>
                                        <field name="document_type" string="Type"/>
                                        <field name="attachment_id"
                                               string="File"
                                               widget="many2one_binary"
                                               required="1"/>
                                        <field name="state"
                                               string="Status"
                                               widget="badge"
                                               decoration-success="state == 'verified'"
                                               decoration-warning="state == 'draft'"
                                               decoration-danger="state == 'rejected'"/>
                                        <field name="uploaded_by" string="Uploaded By" readonly="1"/>
                                        <field name="create_date" string="Uploaded On" readonly="1"/>
                                        <field name="description" string="Notes" optional="hide"/>
                                    </list>
                                </field>
                            </page>

                            <!-- ── Internal Notes ────────────────────────── -->
                            <page string="Internal Notes" name="notes"
                                  groups="alba_loans.group_loan_officer">
                                <field name="internal_notes"
                                       nolabel="1"
                                       placeholder="Officer notes, credit analysis observations, special conditions…"/>
                                <field name="django_application_id"
                                       string="Django Application ID"
                                       groups="base.group_system"
                                       readonly="1"/>
                            </page>

                        </notebook>
                    </sheet>

                    <chatter/>
                </form>
            </field>
        </record>

        <!-- ================================================================
             alba.loan.application — Kanban View
             ================================================================ -->
        <record id="view_alba_loan_application_kanban" model="ir.ui.view">
            <field name="name">alba.loan.application.kanban</field>
            <field name="model">alba.loan.application</field>
            <field name="arch" type="xml">
                <kanban default_group_by="state"
                        class="o_kanban_small_column"
                        quick_create="false"
                        group_create="false">
                    <field name="application_number"/>
                    <field name="customer_id"/>
                    <field name="loan_product_id"/>
                    <field name="requested_amount"/>
                    <field name="approved_amount"/>
                    <field name="state"/>
                    <field name="currency_id"/>
                    <field name="create_date"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_card oe_kanban_global_click">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="application_number"/>
                                        </strong>
                                    </div>
                                    <small class="o_kanban_record_subtitle text-muted">
                                        <field name="create_date" widget="date"/>
                                    </small>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div>
                                        <i class="fa fa-user-o me-1"/>
                                        <field name="customer_id"/>
                                    </div>
                                    <div>
                                        <i class="fa fa-tag me-1"/>
                                        <field name="loan_product_id"/>
                                    </div>
                                    <div class="mt-1">
                                        <strong>Requested: </strong>
                                        <field name="requested_amount" widget="monetary"/>
                                    </div>
                                    <div t-if="record.approved_amount.raw_value">
                                        <strong>Approved: </strong>
                                        <field name="approved_amount" widget="monetary"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- ================================================================
             alba.loan.application — List View
             ================================================================ -->
        <record id="view_alba_loan_application_list" model="ir.ui.view">
            <field name="name">alba.loan.application.list</field>
            <field name="model">alba.loan.application</field>
            <field name="arch" type="xml">
                <list string="Loan Applications"
                      decoration-success="state == 'disbursed'"
                      decoration-danger="state in ('rejected','cancelled')"
                      decoration-warning="state == 'pending_approval'"
                      decoration-info="state not in ('disbursed','rejected','cancelled','pending_approval')">
                    <field name="application_number"/>
                    <field name="customer_id"/>
                    <field name="loan_product_id"/>
                    <field name="requested_amount"/>
                    <field name="approved_amount"/>
                    <field name="tenure_months" string="Tenure (M)"/>
                    <field name="repayment_frequency"/>
                    <field name="state" widget="badge"
                           decoration-success="state == 'disbursed'"
                           decoration-danger="state in ('rejected','cancelled')"
                           decoration-warning="state == 'pending_approval'"
                           decoration-info="state not in ('disbursed','rejected','cancelled','pending_approval')"/>
                    <field name="submitted_date" string="Submitted"/>
                    <field name="approved_by"    string="Approved By"/>
                    <field name="create_date"    string="Created"/>
                    <field name="currency_id" column_invisible="1"/>
                    <field name="can_submit"    column_invisible="1"/>
                    <field name="can_disburse"  column_invisible="1"/>
                </list>
            </field>
        </record>

        <!-- ================================================================
             alba.loan.application — Search View
             ================================================================ -->
        <record id="view_alba_loan_application_search" model="ir.ui.view">
            <field name="name">alba.loan.application.search</field>
            <field name="model">alba.loan.application</field>
            <field name="arch" type="xml">
                <search string="Search Applications">
                    <field name="application_number" string="Application #"/>
                    <field name="customer_id"        string="Customer"/>
                    <field name="loan_product_id"    string="Loan Product"/>
                    <separator/>
                    <filter string="Draft"
                            name="draft"
                            domain="[('state','=','draft')]"/>
                    <filter string="Submitted"
                            name="submitted"
                            domain="[('state','=','submitted')]"/>
                    <filter string="Under Review"
                            name="under_review"
                            domain="[('state','=','under_review')]"/>
                    <filter string="Credit Analysis"
                            name="credit_analysis"
                            domain="[('state','=','credit_analysis')]"/>
                    <filter string="Pending Approval"
                            name="pending_approval"
                            domain="[('state','=','pending_approval')]"/>
                    <filter string="Approved"
                            name="approved"
                            domain="[('state','=','approved')]"/>
                    <filter string="Disbursed"
                            name="disbursed"
                            domain="[('state','=','disbursed')]"/>
                    <filter string="Rejected"
                            name="rejected"
                            domain="[('state','=','rejected')]"/>
                    <filter string="Cancelled"
                            name="cancelled"
                            domain="[('state','=','cancelled')]"/>
                    <separator/>
                    <filter string="In Progress"
                            name="in_progress"
                            domain="[('state','not in',['disbursed','rejected','cancelled'])]"/>
                    <filter string="Submitted This Month"
                            name="this_month"
                            domain="[('submitted_date','&gt;=','2026-03-01')]"/>
                </search>
            </field>
        </record>

    </data>
</odoo>
