<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

    <!-- ================================================================
         alba.loan.application — Form View
         ================================================================ -->
    <record id="view_alba_loan_application_form" model="ir.ui.view">
        <field name="name">alba.loan.application.form</field>
        <field name="model">alba.loan.application</field>
        <field name="arch" type="xml">
            <form string="Loan Application">
                <header>
                    <button name="action_submit" string="Submit Application" type="object" class="btn-primary" invisible="not can_submit"/>
                    <button name="action_under_review" string="Start Review" type="object" class="btn-primary" invisible="not can_review" groups="alba_loans.group_loan_officer"/>
                    <button name="action_credit_analysis" string="Send to Credit Analysis" type="object" class="btn-primary" invisible="not can_credit_analysis" groups="alba_loans.group_loan_officer"/>
                    <button name="action_pending_approval" string="Forward for Approval" type="object" class="btn-primary" invisible="not can_pending_approval" groups="alba_loans.group_loan_officer"/>
                    <button name="action_approve" string="Approve" type="object" class="btn-success" invisible="not can_approve" groups="alba_loans.group_loan_manager"/>
                    <button name="action_employer_verification" string="Send for Employer Verification" type="object" class="btn-primary" invisible="not can_employer_verify" groups="alba_loans.group_loan_officer"/>
                    <button name="action_guarantor_confirmation" string="Send for Guarantor Confirmation" type="object" class="btn-primary" invisible="not can_guarantor_confirm" groups="alba_loans.group_loan_officer"/>
                    <button name="action_open_disburse_wizard" string="Manual Disburse" type="object" class="btn-secondary" invisible="not can_disburse" groups="alba_loans.group_loan_manager"/>
                    <button name="action_auto_disburse" string="Auto-Disburse (M-Pesa)" type="object" class="btn-success" invisible="not can_auto_disburse" groups="alba_loans.group_loan_manager" confirm="This will instantly trigger a B2C transfer to the customer's M-Pesa wallet. Continue?"/>
                    <button name="action_reject" string="Reject" type="object" class="btn-danger" invisible="not can_reject" groups="alba_loans.group_loan_officer"/>
                    <button name="action_cancel" string="Cancel" type="object" class="btn-secondary" invisible="not can_cancel"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,under_review,credit_analysis,pending_approval,approved,disbursed"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_loan" type="object" class="oe_stat_button" icon="fa-money" invisible="loan_count == 0">
                            <field name="loan_count" widget="statinfo" string="Active Loan"/>
                        </button>
                    </div>

                    <widget name="web_ribbon" title="Disbursed" bg_color="bg-success" invisible="state != 'disbursed'"/>
                    <widget name="web_ribbon" title="Rejected" bg_color="bg-danger" invisible="state != 'rejected'"/>

                    <div class="oe_title">
                        <label for="application_number" string="Loan Application"/>
                        <h1>
                            <field name="application_number" readonly="1"/>
                        </h1>
                        <div class="o_row">
                            <field name="risk_score" invisible="1"/>
                            <span class="badge text-bg-info me-2" invisible="risk_score == 0">
                                <i class="fa fa-shield"/> Risk Score: <field name="risk_score"/>
                            </span>
                            <span class="badge text-bg-danger" invisible="not has_guarantor_block">
                                <i class="fa fa-exclamation-triangle"/> Guarantors Needed
                            </span>
                            <span class="badge text-bg-warning" invisible="not has_collateral_block">
                                <i class="fa fa-lock"/> Collateral Needed
                            </span>
                        </div>
                    </div>

                    <!-- ── Application Overview Dashboard ──────────────── -->
                    <div class="row mt-4 mb-4 border rounded p-3 bg-light mx-0 shadow-sm">
                        <div class="col-md-3 border-end text-center">
                            <div class="text-muted small text-uppercase">Requested Amount</div>
                            <div class="h4 mb-0 fw-bold"><field name="requested_amount"/></div>
                        </div>
                        <div class="col-md-3 border-end text-center text-primary">
                            <div class="text-muted small text-uppercase">Loan Product</div>
                            <div class="h5 mb-0 fw-bold"><field name="loan_product_id"/></div>
                        </div>
                        <div class="col-md-3 border-end text-center">
                            <div class="text-muted small text-uppercase">Tenure</div>
                            <div class="h4 mb-0 fw-bold"><field name="tenure_months"/> Months</div>
                        </div>
                        <div class="col-md-3 text-center">
                            <div class="text-muted small text-uppercase">Application Progress</div>
                            <div class="mt-1">
                                <field name="application_progress" widget="progressbar"/>
                            </div>
                        </div>
                    </div>

                    <group>
                        <group string="Borrower Information">
                            <field name="customer_id" options="{'no_create': False}" readonly="state != 'draft'"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Financial Breakdown">
                            <field name="approved_amount" readonly="state not in ('pending_approval','approved','employer_verification','guarantor_confirmation')" groups="alba_loans.group_loan_manager"/>
                            <field name="repayment_frequency" readonly="state != 'draft'"/>
                            <field name="estimated_total_repayable" widget="monetary" string="Indicative Total"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Loan Purpose" name="purpose">
                            <field name="purpose" nolabel="1" readonly="state != 'draft'" placeholder="Describe the purpose…"/>
                        </page>

                        <page string="Dynamic Requirements" name="kyc">
                            <group>
                                <group string="Employment Details" invisible="not product_requires_employer">
                                    <field name="employer_id" readonly="1"/>
                                    <field name="monthly_income" readonly="1" widget="monetary"/>
                                    <field name="job_title" readonly="1"/>
                                </group>
                                <group string="Business Details" invisible="not product_requires_business">
                                    <field name="business_name" readonly="1"/>
                                    <field name="monthly_business_turnover" readonly="1" widget="monetary"/>
                                </group>
                            </group>
                            <!-- Product Requirement Flags (Hidden) -->
                            <field name="product_requires_employer" invisible="1"/>
                            <field name="product_requires_guarantor" invisible="1"/>
                            <field name="product_requires_collateral" invisible="1"/>
                            <field name="product_requires_business" invisible="1"/>
                        </page>

                        <page string="Guarantors" name="guarantors" invisible="not product_requires_guarantor">
                            <div class="alert alert-info py-2 mb-3" role="alert" invisible="not has_guarantor_block">
                                <i class="fa fa-info-circle me-1" aria-label="Info"/> 
                                This product requires at least <field name="product_min_guarantors"/> confirmed guarantor(s).
                            </div>
                            <field name="loan_guarantor_ids" nolabel="1">
                                <list string="Guarantors" editable="bottom">
                                    <field name="guarantor_id"/>
                                    <field name="relationship"/>
                                    <field name="guarantee_amount" widget="monetary"/>
                                    <field name="status" widget="badge" decoration-success="status == 'confirmed'" decoration-warning="status == 'pending'"/>
                                    <button name="action_send_confirmation" string="Send Request" type="object" icon="fa-paper-plane" invisible="status != 'pending'"/>
                                </list>
                            </field>
                        </page>

                        <page string="Collateral" name="collateral" invisible="not product_requires_collateral">
                            <group>
                                <field name="total_collateral_value" widget="monetary"/>
                                <field name="overall_ltv" widget="progressbar" string="Loan to Value %"/>
                            </group>
                            <field name="loan_collateral_ids" nolabel="1">
                                <list string="Collateral Items" editable="bottom">
                                    <field name="collateral_id"/>
                                    <field name="collateral_value" widget="monetary"/>
                                    <field name="ltv_ratio" string="LTV %"/>
                                    <field name="ltv_status" widget="badge" decoration-success="ltv_status == 'good'" decoration-danger="ltv_status == 'exceeded'"/>
                                </list>
                            </field>
                        </page>

                        <page string="Documents &amp; Verification" name="documents">
                            <group string="Application Documents">
                                <field name="loan_document_ids" nolabel="1" context="{'default_partner_id': partner_id}">
                                    <list string="Application Documents" editable="bottom" decoration-info="state == 'draft'" decoration-success="state == 'verified'" decoration-danger="state == 'rejected'">
                                        <field name="name" placeholder="e.g. Payslip"/>
                                        <field name="document_type"/>
                                        <field name="attachment_id" widget="many2one_binary" string="Upload File"/>
                                        <field name="state" widget="badge" 
                                               decoration-success="state == 'verified'" 
                                               decoration-warning="state == 'draft'" 
                                               decoration-danger="state == 'rejected'"/>
                                        <button name="action_verify" string="Verify" type="object" icon="fa-check" class="text-success" invisible="state == 'verified'"/>
                                    </list>
                                </field>
                            </group>
                            <group string="All Customer Documents (Reference)">
                                <field name="all_partner_document_ids" nolabel="1" context="{'hide_partner': False}">
                                    <list string="Documents" decoration-info="state == 'draft'" decoration-success="state == 'verified'" decoration-danger="state == 'rejected'" create="0">
                                        <field name="partner_id" string="Owner"/>
                                        <field name="name"/>
                                        <field name="document_type"/>
                                        <field name="attachment_id" widget="many2one_binary" string="File"/>
                                        <field name="create_date" string="Uploaded" widget="date"/>
                                        <field name="state" widget="badge" 
                                               decoration-success="state == 'verified'" 
                                               decoration-warning="state == 'draft'" 
                                               decoration-danger="state == 'rejected'"/>
                                    </list>
                                </field>
                            </group>
                        </page>

                        <page string="Timeline" name="timeline">
                            <group col="4">
                                <field name="submitted_date" readonly="1"/>
                                <field name="reviewed_date" readonly="1"/>
                                <field name="approved_date" readonly="1"/>
                                <field name="disbursed_date" readonly="1"/>
                            </group>
                        </page>

                        <page string="Portal &amp; Technical" name="technical" groups="base.group_no_one">
                            <group>
                                <field name="django_application_id" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ================================================================
         alba.loan.application — List View
         ================================================================ -->
    <record id="view_alba_loan_application_list" model="ir.ui.view">
        <field name="name">alba.loan.application.list</field>
        <field name="model">alba.loan.application</field>
        <field name="arch" type="xml">
            <list string="Loan Applications"
                  decoration-success="state == 'disbursed'"
                  decoration-danger="state == 'rejected'"
                  decoration-warning="state == 'pending_approval'">
                <field name="application_number"/>
                <field name="customer_id"/>
                <field name="loan_product_id"/>
                <field name="requested_amount" sum="Total Requested"/>
                <field name="approved_amount" sum="Total Approved"/>
                <field name="application_progress" widget="progressbar" string="Progress"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'disbursed'"
                       decoration-danger="state == 'rejected'"
                       decoration-info="state not in ('disbursed','rejected')"/>
                <field name="submitted_date" widget="date"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ================================================================
         alba.loan.application — Kanban View
         ================================================================ -->
    <record id="view_alba_loan_application_kanban" model="ir.ui.view">
        <field name="name">alba.loan.application.kanban</field>
        <field name="model">alba.loan.application</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column" sample="1">
                <field name="application_number"/>
                <field name="customer_id"/>
                <field name="loan_product_id"/>
                <field name="requested_amount"/>
                <field name="application_progress"/>
                <field name="risk_score"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title h5 mb-1">
                                        <field name="application_number"/>
                                    </strong>
                                    <span class="text-muted small">
                                        <field name="customer_id"/>
                                    </span>
                                </div>
                            </div>
                            <div class="o_kanban_record_body my-2">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="text-muted small">Requested</span>
                                    <span class="fw-bold"><field name="requested_amount" widget="monetary"/></span>
                                </div>
                                <div class="small mb-1 text-primary">
                                    <i class="fa fa-tag me-1" title="Product"/> <field name="loan_product_id"/>
                                </div>
                                <div class="mt-2">
                                    <div class="text-muted small mb-1">Approval Progress</div>
                                    <field name="application_progress" widget="progressbar"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <span t-attf-class="badge rounded-pill text-bg-#{record.risk_score.raw_value > 80 ? 'success' : record.risk_score.raw_value > 50 ? 'warning' : 'danger'}">
                                        Risk: <field name="risk_score"/>
                                    </span>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="create_date" widget="date"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ================================================================
         alba.loan.application — Search View
         ================================================================ -->
    <record id="view_alba_loan_application_search" model="ir.ui.view">
        <field name="name">alba.loan.application.search</field>
        <field name="model">alba.loan.application</field>
        <field name="arch" type="xml">
            <search>
                <field name="application_number"/>
                <field name="customer_id"/>
                <field name="loan_product_id"/>
                <filter string="In Progress" name="in_progress" domain="[('state','not in',['disbursed','rejected','cancelled'])]"/>
                <filter string="Pending Approval" name="pending_approval" domain="[('state','=','pending_approval')]"/>
                <separator/>
                <filter string="Large Loans (> 1M)" name="high_value" domain="[('requested_amount','>',1000000)]"/>
                <separator/>
                <group>
                    <filter string="Status" name="group_status" context="{'group_by': 'state'}"/>
                    <filter string="Product" name="group_product" context="{'group_by': 'loan_product_id'}"/>
                    <filter string="Customer" name="group_customer" context="{'group_by': 'customer_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Loan Application Graph View -->
    <record id="view_loan_application_graph" model="ir.ui.view">
        <field name="name">alba.loan.application.graph</field>
        <field name="model">alba.loan.application</field>
        <field name="arch" type="xml">
            <graph string="Loan Applications" type="line">
                <field name="submitted_date" type="row"/>
                <field name="requested_amount" type="measure"/>
            </graph>
        </field>
    </record>

</data>
</odoo>
