<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ================================================================
             alba.loan.category — Views
             ================================================================ -->
        <record id="view_alba_loan_category_list" model="ir.ui.view">
            <field name="name">alba.loan.category.list</field>
            <field name="model">alba.loan.category</field>
            <field name="arch" type="xml">
                <list string="Loan Categories" editable="bottom">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="color" widget="color_picker"/>
                    <field name="product_count"/>
                    <field name="active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <record id="action_alba_loan_category" model="ir.actions.act_window">
            <field name="name">Loan Categories</field>
            <field name="res_model">alba.loan.category</field>
            <field name="view_mode">list,form</field>
        </record>


        <!-- ================================================================
             alba.loan.product — Form View
             ================================================================ -->
        <record id="view_alba_loan_product_form" model="ir.ui.view">
            <field name="name">alba.loan.product.form</field>
            <field name="model">alba.loan.product</field>
            <field name="arch" type="xml">
                <form string="Loan Product">
                    <header>
                        <button name="action_view_applications"
                                string="View Applications"
                                type="object"
                                class="btn-secondary"/>
                        <field name="is_active" widget="boolean_toggle"
                               options="{'terminology': {'string_true': 'Active', 'string_false': 'Archived'}}"/>
                    </header>

                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_applications"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-file-text-o">
                                <field name="application_count"
                                       widget="statinfo"
                                       string="Applications"/>
                            </button>
                        </div>

                        <div class="oe_title">
                            <label for="name" string="Product Name"/>
                            <h1>
                                <field name="name"
                                       placeholder="e.g. Business Loan — Standard"/>
                            </h1>
                            <div class="o_row">
                                <field name="code"
                                       placeholder="Product Code e.g. BL-STD"/>
                                <field name="category_id" options="{'no_create_edit': False, 'no_open': False}"/>
                                <field name="color" widget="color_picker" nolabel="1"/>
                            </div>
                        </div>

                        <group>
                            <group string="Loan Amount Limits">
                                <field name="currency_id" invisible="1"/>
                                <field name="min_amount"/>
                                <field name="max_amount"/>
                                <field name="min_tenure_months"/>
                                <field name="max_tenure_months"/>
                                <field name="repayment_frequency"/>
                            </group>
                            <group string="Interest Configuration">
                                <field name="interest_method"/>
                                <field name="interest_rate"
                                       widget="percentage"
                                       options="{'type': 'number', 'step': 0.01}"/>
                            </group>
                        </group>

                        <notebook>

                            <!-- ── Requirements ──────────────────────────── -->
                            <page string="Requirements &amp; Automation" name="requirements">
                                <group>
                                    <group string="Futuristic Automation">
                                        <field name="auto_approve_score_threshold"/>
                                        <field name="auto_disburse"/>
                                    </group>
                                    <group string="Dynamic UI Triggers">
                                        <label for="requires_employer" string="Employment Flow"/>
                                        <div class="o_row">
                                            <field name="requires_employer"/>
                                            <span class="text-muted" invisible="not requires_employer">
                                                <i class="fa fa-info-circle"/> Shows Employer &amp; Job Title
                                            </span>
                                        </div>
                                        
                                        <label for="requires_guarantor" string="Guarantor Flow"/>
                                        <div class="o_row">
                                            <field name="requires_guarantor"/>
                                            <field name="min_guarantors" invisible="not requires_guarantor" placeholder="Min Qty"/>
                                            <span class="text-muted" invisible="not requires_guarantor">
                                                <i class="fa fa-users"/> Automated SMS requests
                                            </span>
                                        </div>

                                        <label for="requires_collateral" string="Security Flow"/>
                                        <div class="o_row">
                                            <field name="requires_collateral"/>
                                            <span class="text-muted" invisible="not requires_collateral">
                                                <i class="fa fa-shield"/> LTV Monitoring &amp; Auto-Pledge
                                            </span>
                                        </div>

                                        <label for="requires_business_info" string="Business Flow"/>
                                        <div class="o_row">
                                            <field name="requires_business_info"/>
                                            <span class="text-muted" invisible="not requires_business_info">
                                                <i class="fa fa-briefcase"/> Registration &amp; Turnover tracking
                                            </span>
                                        </div>
                                    </group>
                                    <group string="Mandatory Documents">
                                        <field name="requires_payslip" widget="boolean_toggle"/>
                                        <field name="requires_business_reg" widget="boolean_toggle"/>
                                        <div colspan="2" class="alert alert-info mt-2" role="alert">
                                            <strong>Pro Tip:</strong> These flags drive the <i>invisible</i> logic on the loan application form. Zero coding required for new products.
                                        </div>
                                    </group>
                                </group>
                            </page>

                            <!-- ── Fees ──────────────────────────────────── -->
                            <page string="Fees" name="fees">
                                <group>
                                    <group string="Fee Percentages (% of Principal)">
                                        <field name="origination_fee_percentage"/>
                                        <field name="processing_fee_percentage"/>
                                        <field name="insurance_fee_percentage"/>
                                    </group>
                                </group>
                            </page>

                            <!-- ── Accounting ─────────────────────────────── -->
                            <page string="Accounting" name="accounting">
                                <group>
                                    <group string="Income Accounts">
                                        <field name="account_loan_receivable_id"
                                               options="{'no_create': True}"/>
                                        <field name="account_interest_income_id"
                                               options="{'no_create': True}"/>
                                        <field name="account_fees_income_id"
                                               options="{'no_create': True}"/>
                                    </group>
                                    <group string="Company">
                                        <field name="company_id"
                                               groups="base.group_multi_company"/>
                                    </group>
                                </group>
                            </page>

                            <!-- ── Description ────────────────────────────── -->
                            <page string="Description" name="description">
                                <field name="description"
                                       nolabel="1"
                                       placeholder="Describe the loan product, eligibility criteria, and any special conditions…"/>
                            </page>

                        </notebook>
                    </sheet>

                    <chatter/>
                </form>
            </field>
        </record>

        <!-- ================================================================
             alba.loan.product — List View
             ================================================================ -->
        <record id="view_alba_loan_product_list" model="ir.ui.view">
            <field name="name">alba.loan.product.list</field>
            <field name="model">alba.loan.product</field>
            <field name="arch" type="xml">
                <list string="Loan Products"
                      decoration-muted="is_active == False">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="category_id" widget="badge" 
                           options="{'color_field': 'color'}"/>
                    <field name="min_amount"/>
                    <field name="max_amount"/>
                    <field name="interest_rate" string="Rate (% p.m.)"/>
                    <field name="interest_method"/>
                    <field name="min_tenure_months" string="Min Tenure"/>
                    <field name="max_tenure_months" string="Max Tenure"/>
                    <field name="repayment_frequency"/>
                    <field name="application_count" string="Applications"/>
                    <field name="is_active" widget="boolean_toggle"/>
                    <field name="currency_id" column_invisible="1"/>
                </list>
            </field>
        </record>

        <!-- ================================================================
             alba.loan.product — Search View
             ================================================================ -->
        <record id="view_alba_loan_product_search" model="ir.ui.view">
            <field name="name">alba.loan.product.search</field>
            <field name="model">alba.loan.product</field>
            <field name="arch" type="xml">
                <search string="Search Loan Products">
                    <field name="name"  string="Name"/>
                    <field name="code"  string="Code"/>
                    <separator/>
                    <filter string="Active"
                            name="active"
                            domain="[('is_active','=',True)]"/>
                    <filter string="Archived"
                            name="archived"
                            domain="[('is_active','=',False)]"/>
                    <separator/>
                    <filter string="Category"
                            name="group_by_category"
                            context="{'group_by': 'category_id'}"/>
                    <separator/>
                    <filter string="Flat Rate"
                            name="flat_rate"
                            domain="[('interest_method','=','flat_rate')]"/>
                    <filter string="Reducing Balance"
                            name="reducing_balance"
                            domain="[('interest_method','=','reducing_balance')]"/>
                </search>
            </field>
        </record>

        <!-- ================================================================
             alba.loan.product — Kanban View
             ================================================================ -->
        <record id="view_alba_loan_product_kanban" model="ir.ui.view">
            <field name="name">alba.loan.product.kanban</field>
            <field name="model">alba.loan.product</field>
            <field name="arch" type="xml">
                <kanban class="o_alba_product_kanban" default_group_by="category_id" sample="1">
                    <field name="id"/>
                    <field name="name"/>
                    <field name="category_id"/>
                    <field name="color"/>
                    <field name="interest_rate"/>
                    <field name="interest_method"/>
                    <field name="min_amount"/>
                    <field name="max_amount"/>
                    <field name="currency_id"/>
                    <field name="application_count"/>
                    <templates>
                        <t t-name="card">
                            <div t-attf-class="#{kanban_color(record.color.raw_value)} oe_kanban_global_click o_kanban_record_has_image_fill">
                                <div class="oe_kanban_details">
                                    <div class="o_kanban_record_top">
                                        <div class="o_kanban_record_headings">
                                            <strong class="o_kanban_record_title">
                                                <field name="name"/>
                                            </strong>
                                            <small class="o_kanban_record_subtitle">
                                                <field name="code"/>
                                            </small>
                                        </div>
                                        <div class="o_dropdown_kanban dropdown">
                                            <a class="dropdown-toggle o-no-caret btn" role="button" data-bs-toggle="dropdown" href="#" aria-label="Settings" title="Settings">
                                                <span class="fa fa-ellipsis-v"/>
                                            </a>
                                            <div class="dropdown-menu" role="menu">
                                                <ul class="oe_kanban_colorpicker" data-field="color"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="o_kanban_record_body mt-2">
                                        <div class="row">
                                            <div class="col-6">
                                                <strong>Rate: </strong> <field name="interest_rate"/>%
                                            </div>
                                            <div class="col-6">
                                                <strong>Method: </strong> <field name="interest_method"/>
                                            </div>
                                        </div>
                                        <div class="mt-2">
                                            <field name="min_amount" widget="monetary"/> - <field name="max_amount" widget="monetary"/>
                                        </div>
                                    </div>
                                    <div class="o_kanban_record_bottom mt-3">
                                        <div class="oe_kanban_bottom_left">
                                            <span class="badge badge-pill badge-info" title="Applications">
                                                <i class="fa fa-file-text-o"/> <field name="application_count"/>
                                            </span>
                                        </div>
                                        <div class="oe_kanban_bottom_right">
                                            <field name="category_id" widget="label_selection" options="{'color_field': 'color'}"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

    </data>
</odoo>
