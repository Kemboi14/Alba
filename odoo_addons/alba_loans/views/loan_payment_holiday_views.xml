<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_loan_payment_holiday_tree" model="ir.ui.view">
        <field name="name">alba.loan.payment.holiday.tree</field>
        <field name="model">alba.loan.payment.holiday</field>
        <field name="arch" type="xml">
            <list decoration-muted="state=='cancelled'" decoration-success="state=='completed'" decoration-info="state=='active'">
                <field name="name"/>
                <field name="loan_id"/>
                <field name="customer_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="holiday_months"/>
                <field name="reason"/>
                <field name="interest_accrual"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_loan_payment_holiday_form" model="ir.ui.view">
        <field name="name">alba.loan.payment.holiday.form</field>
        <field name="model">alba.loan.payment.holiday</field>
        <field name="arch" type="xml">
            <form string="Payment Holiday">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state != 'pending'"/>
                    <button name="action_activate" string="Activate" type="object" class="oe_highlight" invisible="state != 'approved'"/>
                    <button name="action_complete" string="Complete" type="object" class="oe_highlight" invisible="state != 'active'"/>
                    <button name="action_reject" string="Reject" type="object" invisible="state not in ('draft', 'pending')"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state not in ('draft', 'pending')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,pending,approved,active,completed"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group>
                        <group string="Loan">
                            <field name="loan_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                            <field name="customer_id" readonly="1"/>
                            <field name="current_outstanding" readonly="1"/>
                            <field name="current_emi" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Eligibility">
                            <field name="is_eligible" readonly="1"/>
                            <field name="eligibility_warnings" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Holiday Details">
                            <field name="start_date" readonly="state != 'draft'"/>
                            <field name="end_date" readonly="state != 'draft'"/>
                            <field name="holiday_months" readonly="1"/>
                            <field name="reason" readonly="state != 'draft'"/>
                            <field name="reason_notes" readonly="state != 'draft'"/>
                        </group>
                        <group string="Interest Handling">
                            <field name="interest_accrual" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <group string="Financial Impact">
                        <group>
                            <field name="deferred_principal" readonly="1"/>
                            <field name="deferred_interest" readonly="1"/>
                            <field name="total_deferred" readonly="1"/>
                        </group>
                        <group>
                            <field name="new_outstanding" readonly="1"/>
                            <field name="new_maturity_date" readonly="1"/>
                        </group>
                    </group>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_loan_payment_holiday" model="ir.actions.act_window">
        <field name="name">Payment Holidays</field>
        <field name="res_model">alba.loan.payment.holiday</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_loan_payment_holiday" name="Payment Holidays" parent="menu_alba_loans_root_active" action="action_loan_payment_holiday" sequence="33"/>
</odoo>
