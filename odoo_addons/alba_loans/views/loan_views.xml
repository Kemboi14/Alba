<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ================================================================
             alba.loan — Form View
             ================================================================ -->
        <record id="view_alba_loan_form" model="ir.ui.view">
            <field name="name">alba.loan.form</field>
            <field name="model">alba.loan</field>
            <field name="arch" type="xml">
                <form string="Loan">
                    <header>
                        <button name="action_generate_schedule"
                                string="Generate Schedule"
                                type="object"
                                class="btn-primary"
                                invisible="schedule_generated == True"
                                groups="alba_loans.group_loan_officer"/>
                        <button name="action_post_disbursement_entry"
                                string="Post Disbursement Entry"
                                type="object"
                                class="btn-primary"
                                invisible="disbursement_move_id != False"
                                groups="account.group_account_manager"/>
                        <button name="action_mark_npl"
                                string="Mark as NPL"
                                type="object"
                                class="btn-warning"
                                invisible="state != 'active'"
                                groups="alba_loans.group_loan_manager"/>
                        <button name="action_close"
                                string="Close Loan"
                                type="object"
                                class="btn-success"
                                invisible="state != 'active'"
                                groups="alba_loans.group_loan_manager"/>
                        <button name="action_write_off"
                                string="Write Off"
                                type="object"
                                class="btn-danger"
                                invisible="state not in ('active','npl')"
                                groups="alba_loans.group_loan_manager"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="active,npl,closed,written_off"/>
                    </header>

                    <sheet>
                        <!-- Smart Buttons -->
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_schedule"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-calendar">
                                <div class="o_stat_info">
                                    <span class="o_stat_value">
                                        <field name="tenure_months"/>
                                    </span>
                                    <span class="o_stat_text">Instalments</span>
                                </div>
                            </button>
                            <button name="action_view_repayments"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-credit-card">
                                <field name="repayment_count"
                                       widget="statinfo"
                                       string="Payments"/>
                            </button>
                            <button type="object"
                                    name="action_view_repayments"
                                    class="oe_stat_button"
                                    icon="fa-balance-scale">
                                <div class="o_stat_info">
                                    <field name="outstanding_balance" widget="monetary"/>
                                    <span class="o_stat_text">Outstanding</span>
                                </div>
                            </button>
                        </div>

                        <!-- NPL / Written-Off warning banners -->
                        <div class="alert alert-danger" role="alert"
                             invisible="state != 'written_off'">
                            <strong>This loan has been written off.</strong>
                        </div>
                        <div class="alert alert-warning" role="alert"
                             invisible="state != 'npl'">
                            <strong>Non-Performing Loan (NPL)</strong> —
                            <field name="days_in_arrears" readonly="1"/> days in arrears.
                        </div>

                        <div class="oe_title">
                            <label for="loan_number" string="Loan Number"/>
                            <h1>
                                <field name="loan_number" readonly="1"/>
                            </h1>
                        </div>

                        <group>
                            <group string="Loan Parties">
                                <field name="application_id" readonly="1"/>
                                <field name="customer_id"    readonly="1"/>
                                <field name="loan_product_id" readonly="1"/>
                                <field name="company_id"
                                       groups="base.group_multi_company"
                                       readonly="1"/>
                                <field name="currency_id" invisible="1"/>
                            </group>
                            <group string="Loan Terms">
                                <field name="principal_amount"/>
                                <field name="interest_rate"/>
                                <field name="interest_method"/>
                                <field name="tenure_months"/>
                                <field name="repayment_frequency"/>
                                <field name="disbursement_date"/>
                                <field name="maturity_date" readonly="1"/>
                            </group>
                        </group>

                        <group string="Financial Summary" col="4">
                            <field name="total_repayable"    readonly="1"/>
                            <field name="total_paid"         readonly="1"/>
                            <field name="outstanding_balance" readonly="1"/>
                            <field name="arrears_amount"     readonly="1"/>
                        </group>

                        <group string="Portfolio at Risk" col="4"
                               invisible="state == 'closed'">
                            <field name="days_in_arrears" readonly="1"/>
                            <field name="par_bucket" widget="badge" readonly="1"
                                   decoration-success="par_bucket == 'current'"
                                   decoration-warning="par_bucket in ('1_30','31_60')"
                                   decoration-danger="par_bucket in ('61_90','91_180','over_180')"/>
                        </group>

                        <notebook>

                            <!-- ── Repayment Schedule ────────────────────── -->
                            <page string="Repayment Schedule" name="schedule">
                                <div class="alert alert-info" role="alert"
                                     invisible="schedule_generated == True">
                                    <i class="fa fa-info-circle me-1"/>
                                    Click <strong>Generate Schedule</strong> in the
                                    header to auto-create the amortisation schedule
                                    for this loan.
                                </div>
                                <field name="repayment_schedule_ids"
                                       mode="list"
                                       readonly="1"
