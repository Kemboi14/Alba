<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

    <!-- ================================================================
         alba.loan — Form View
         ================================================================ -->
    <record id="view_alba_loan_form" model="ir.ui.view">
        <field name="name">alba.loan.form</field>
        <field name="model">alba.loan</field>
        <field name="arch" type="xml">
            <form string="Loan">
                <header>
                    <button name="action_generate_schedule" string="Generate Schedule" type="object" class="btn-primary" invisible="schedule_generated == True" groups="alba_loans.group_loan_officer"/>
                    <button name="action_post_disbursement_entry" string="Post Disbursement Entry" type="object" class="btn-primary" invisible="disbursement_move_id != False" groups="account.group_account_manager"/>
                    <button name="action_mark_npl" string="Mark as NPL" type="object" class="btn-warning" invisible="state != 'active'" groups="alba_loans.group_loan_manager"/>
                    <button name="action_close" string="Close Loan" type="object" class="btn-success" invisible="state != 'active'" groups="alba_loans.group_loan_manager"/>
                    <button name="action_write_off" string="Write Off" type="object" class="btn-danger" invisible="state not in ('active','npl')" groups="alba_loans.group_loan_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="active,npl,closed,written_off"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box" invisible="not id">
                        <button name="action_view_schedule" type="object" class="oe_stat_button" icon="fa-calendar">
                            <div class="o_stat_info">
                                <span class="o_stat_value"><field name="remaining_tenure"/></span>
                                <span class="o_stat_text">Remaining</span>
                            </div>
                        </button>
                        <button name="action_view_repayments" type="object" class="oe_stat_button" icon="fa-credit-card">
                            <field name="repayment_count" widget="statinfo" string="Payments"/>
                        </button>
                        <button type="object" name="action_view_repayments" class="oe_stat_button" icon="fa-balance-scale">
                            <div class="o_stat_info">
                                <field name="outstanding_balance" widget="monetary"/>
                                <span class="o_stat_text">Outstanding</span>
                            </div>
                        </button>
                    </div>

                    <widget name="web_ribbon" title="Paid" bg_color="bg-success" invisible="state != 'closed'"/>
                    <widget name="web_ribbon" title="NPL" bg_color="bg-danger" invisible="state != 'npl'"/>

                    <div class="oe_title">
                        <label for="loan_number" string="Loan Account"/>
                        <h1>
                            <field name="loan_number" readonly="1"/>
                        </h1>
                        <div class="o_row">
                            <field name="par_bucket" invisible="1"/>
                            <span class="badge text-bg-success" invisible="par_bucket != 'current'">
                                <i class="fa fa-check-circle"/> Account Current
                            </span>
                            <span class="badge text-bg-danger" invisible="par_bucket == 'current'">
                                <i class="fa fa-warning" title="Warning"/> <field name="days_in_arrears"/> Days Overdue
                            </span>
                        </div>
                    </div>

                    <!-- ── Repayment Dashboard ────────────────────────── -->
                    <div class="row mt-4 mb-4 border rounded p-3 bg-light mx-0 shadow-sm">
                        <div class="col-md-3 border-end text-center">
                            <div class="text-muted small text-uppercase">Total Repayable</div>
                            <div class="h4 mb-0 fw-bold"><field name="total_repayable" widget="monetary"/></div>
                        </div>
                        <div class="col-md-3 border-end text-center text-success">
                            <div class="text-muted small text-uppercase">Total Paid</div>
                            <div class="h4 mb-0 fw-bold"><field name="total_paid" widget="monetary"/></div>
                        </div>
                        <div class="col-md-3 border-end text-center text-primary">
                            <div class="text-muted small text-uppercase">Outstanding</div>
                            <div class="h4 mb-0 fw-bold"><field name="outstanding_balance" widget="monetary"/></div>
                        </div>
                        <div class="col-md-3 text-center">
                            <div class="text-muted small text-uppercase">Collection Progress</div>
                            <div class="mt-1">
                                <field name="repayment_progress" widget="progressbar"/>
                            </div>
                        </div>
                    </div>

                    <!-- ── Next Repayment Info ────────────────────────── -->
                    <div class="row mb-4 px-3" invisible="state != 'active'">
                        <div class="col-12 border border-primary rounded p-2 bg-white d-flex align-items-center justify-content-between">
                            <div>
                                <i class="fa fa-clock-o text-primary me-2"/>
                                <span class="text-muted small text-uppercase">Next Payment: </span>
                                <span class="fw-bold text-primary ms-1"><field name="next_payment_amount" widget="monetary"/></span>
                                <span class="text-muted ms-2 small">due on </span>
                                <span class="fw-bold"><field name="next_payment_due_date"/></span>
                            </div>
                            <span class="badge rounded-pill text-bg-danger" invisible="days_until_due &gt;= 0 or not days_until_due">
                                <field name="days_until_due"/> Days Overdue
                            </span>
                            <span class="badge rounded-pill text-bg-info" invisible="days_until_due &lt; 0 or not days_until_due">
                                <field name="days_until_due"/> Days Left
                            </span>
                        </div>
                    </div>

                    <group>
                        <group string="Borrower &amp; Product">
                            <field name="customer_id" readonly="1"/>
                            <field name="loan_product_id" readonly="1"/>
                            <field name="application_id" readonly="1"/>
                        </group>
                        <group string="Loan Terms">
                            <field name="principal_amount" readonly="1"/>
                            <field name="interest_rate" readonly="1"/>
                            <field name="interest_method" readonly="1"/>
                            <field name="tenure_months" readonly="1"/>
                            <field name="repayment_frequency" readonly="1"/>
                            <field name="disbursement_date" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Repayment Schedule" name="schedule">
                            <field name="repayment_schedule_ids" mode="list" readonly="1">
                                <list string="Schedule" decoration-danger="status == 'overdue'" decoration-success="status == 'paid'">
                                    <field name="installment_number" string="#"/>
                                    <field name="due_date"/>
                                    <field name="opening_balance"/>
                                    <field name="principal_due"/>
                                    <field name="interest_due"/>
                                    <field name="total_due" fw_bold="1"/>
                                    <field name="total_paid" string="Paid"/>
                                    <field name="balance_due" string="Balance" decoration-danger="balance_due > 0"/>
                                    <field name="status" widget="badge" decoration-success="status == 'paid'" decoration-danger="status == 'overdue'"/>
                                </list>
                            </field>
                        </page>

                        <page string="Repayment History" name="repayments">
                            <field name="repayment_ids" mode="list" readonly="1">
                                <list string="Repayments" decoration-success="state == 'posted'" decoration-danger="state == 'reversed'">
                                    <field name="payment_date"/>
                                    <field name="payment_reference"/>
                                    <field name="amount_paid" sum="Total"/>
                                    <field name="payment_method" widget="badge"/>
                                    <field name="state" widget="badge" decoration-success="state == 'posted'"/>
                                </list>
                            </field>
                        </page>

                        <page string="Portfolio Quality" name="par">
                            <group>
                                <field name="days_in_arrears"/>
                                <field name="par_bucket" widget="badge" decoration-success="par_bucket == 'current'" decoration-danger="par_bucket != 'current'"/>
                                <field name="arrears_amount" widget="monetary"/>
                            </group>
                        </page>

                        <page string="Accounting" name="accounting" groups="account.group_account_user">
                            <group>
                                <group string="Ledger Entries">
                                    <field name="journal_id"/>
                                    <field name="disbursement_move_id"/>
                                </group>
                                <group string="Portal Link">
                                    <field name="django_loan_id" readonly="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ================================================================
         alba.loan — List View
         ================================================================ -->
    <record id="view_alba_loan_list" model="ir.ui.view">
        <field name="name">alba.loan.list</field>
        <field name="model">alba.loan</field>
        <field name="arch" type="xml">
            <list string="Loans"
                  decoration-danger="state in ('npl','written_off')"
                  decoration-success="state == 'closed'">
                <field name="loan_number"/>
                <field name="customer_id"/>
                <field name="principal_amount" sum="Total Principal"/>
                <field name="repayment_progress" widget="progressbar" string="Progress"/>
                <field name="outstanding_balance" sum="Total Outstanding"/>
                <field name="arrears_amount" sum="Total Arrears" decoration-danger="arrears_amount > 0"/>
                <field name="days_in_arrears" string="Overdue"/>
                <field name="par_bucket" widget="badge" decoration-success="par_bucket == 'current'" decoration-danger="par_bucket != 'current'"/>
                <field name="state" widget="badge" decoration-success="state == 'closed'" decoration-danger="state == 'npl'" decoration-info="state == 'active'"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ================================================================
         alba.loan — Search View
         ================================================================ -->
    <record id="view_alba_loan_search" model="ir.ui.view">
        <field name="name">alba.loan.search</field>
        <field name="model">alba.loan</field>
        <field name="arch" type="xml">
            <search>
                <field name="loan_number"/>
                <field name="customer_id"/>
                <separator/>
                <filter string="Active" name="active" domain="[('state','=','active')]"/>
                <filter string="Non-Performing (NPL)" name="npl" domain="[('state','=','npl')]"/>
                <separator/>
                <filter string="Overdue" name="overdue" domain="[('arrears_amount','>',0)]"/>
                <separator/>
                <group>
                    <filter string="Product" name="group_product" context="{'group_by': 'loan_product_id'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'state'}"/>
                    <filter string="PAR Bucket" name="group_par" context="{'group_by': 'par_bucket'}"/>
                </group>
            </search>
        </field>
    </record>

</data>
</odoo>
