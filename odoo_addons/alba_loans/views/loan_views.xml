                                </field>
                            </page>

                            <!-- ── Accounting ────────────────────────────── -->
                            <page string="Accounting" name="accounting"
                                  groups="account.group_account_user">
                                <group>
                                    <group string="Disbursement">
                                        <field name="journal_id"/>
                                        <field name="disbursement_move_id" readonly="1"/>
                                    </group>
                                    <group string="Integration">
                                        <field name="django_loan_id"
                                               string="Django Loan ID"
                                               groups="base.group_system"
                                               readonly="1"/>
                                        <field name="schedule_generated" readonly="1"/>
                                    </group>
                                </group>
                            </page>

                            <!-- ── Notes ─────────────────────────────────── -->
                            <page string="Notes" name="notes">
                                <field name="notes"
                                       nolabel="1"
                                       placeholder="Internal notes about this loan…"/>
                            </page>

                        </notebook>
                    </sheet>

                    <chatter/>
                </form>
            </field>
        </record>

        <!-- ================================================================
             alba.loan — List View
             ================================================================ -->
        <record id="view_alba_loan_list" model="ir.ui.view">
            <field name="name">alba.loan.list</field>
            <field name="model">alba.loan</field>
            <field name="arch" type="xml">
                <list string="Loans"
                      decoration-danger="state in ('npl','written_off')"
                      decoration-success="state == 'closed'"
                      decoration-muted="state == 'written_off'">
                    <field name="loan_number"/>
                    <field name="customer_id"/>
                    <field name="loan_product_id"/>
                    <field name="principal_amount"/>
                    <field name="interest_rate" string="Rate (%)"/>
                    <field name="interest_method"/>
                    <field name="tenure_months" string="Tenure (M)"/>
                    <field name="disbursement_date"/>
                    <field name="maturity_date"/>
                    <field name="total_repayable"/>
                    <field name="total_paid"/>
                    <field name="outstanding_balance"/>
                    <field name="arrears_amount"/>
                    <field name="days_in_arrears"/>
                    <field name="par_bucket" widget="badge"
                           decoration-success="par_bucket == 'current'"
                           decoration-warning="par_bucket in ('1_30','31_60')"
                           decoration-danger="par_bucket in ('61_90','91_180','over_180')"/>
                    <field name="state" widget="badge"
                           decoration-success="state == 'closed'"
                           decoration-danger="state in ('npl','written_off')"
                           decoration-info="state == 'active'"/>
                    <field name="currency_id" column_invisible="1"/>
                </list>
            </field>
        </record>

