    <!-- ================================================================
         Wizard Window Actions — defined as ir.actions.server so the
         model_id FK (not a string res_model) avoids the act_window
         constraint that silently fails for new TransientModels in
         Odoo 19 upgrade mode.
         ================================================================ -->
    <record id="action_alba_report_par_wizard" model="ir.actions.server">
        <field name="name">PAR Report</field>
        <field name="model_id" ref="model_alba_report_par"/>
        <field name="state">code</field>
        <field name="code">action = {'type': 'ir.actions.act_window', 'name': 'PAR Report', 'res_model': 'alba.report.par', 'view_mode': 'form', 'target': 'new'}</field>
    </record>

