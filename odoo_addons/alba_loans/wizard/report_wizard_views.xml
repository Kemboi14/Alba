<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- PAR Report Wizard View -->
        <record id="view_alba_report_par_wizard" model="ir.ui.view">
            <field name="name">alba.report.par.wizard.form</field>
            <field name="model">alba.report.par.wizard</field>
            <field name="arch" type="xml">
                <form string="Portfolio at Risk (PAR) Report">
                    <group>
                        <field name="as_of_date"/>
                    </group>
                    <footer>
                        <button name="action_generate_report" string="Generate PDF" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- NPL Report Wizard View -->
        <record id="view_alba_report_npl_wizard" model="ir.ui.view">
