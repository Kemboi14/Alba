<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ================================================================
             Alba Investors — Sequences
             ================================================================ -->

        <!-- Investor Number: INV-0001 -->
        <record id="seq_alba_investor" model="ir.sequence">
            <field name="name">Alba Investor Number</field>
            <field name="code">alba.investor.seq</field>
            <field name="prefix">INV-</field>
            <field name="suffix"></field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
            <field name="use_date_range">False</field>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <!-- Investment Account Number: IM-0001 -->
        <record id="seq_alba_investment" model="ir.sequence">
            <field name="name">Alba Investment Account Number</field>
            <field name="code">alba.investment.seq</field>
            <field name="prefix">IM-</field>
            <field name="suffix"></field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
            <field name="use_date_range">False</field>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <!-- Investment Statement Reference: IS-0001 -->
        <record id="seq_alba_investment_statement" model="ir.sequence">
            <field name="name">Alba Investment Statement Reference</field>
            <field name="code">alba.investment.statement.seq</field>
            <field name="prefix">IS-</field>
            <field name="suffix"></field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
            <field name="use_date_range">False</field>
            <field name="company_id" ref="base.main_company"/>
        </record>

    </data>
</odoo>
