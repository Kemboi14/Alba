<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

    <!-- ================================================================
         alba.investment — Form View
         ================================================================ -->
    <record id="view_alba_investment_form" model="ir.ui.view">
        <field name="name">alba.investment.form</field>
        <field name="model">alba.investment</field>
        <field name="arch" type="xml">
            <form string="Investment Account">
                <header>
                    <button name="action_accrue_monthly_interest"
                            string="Accrue Monthly Interest"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'active'"
                            groups="alba_investors.group_investor_officer"/>
                    <button name="action_mature"
                            string="Mark as Matured"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'active'"
                            groups="alba_investors.group_investor_manager"/>
                    <button name="action_withdraw"
                            string="Mark as Withdrawn"
                            type="object"
                            class="btn-warning"
                            invisible="state not in ('active','matured')"
                            groups="alba_investors.group_investor_manager"/>
                    <button name="action_suspend"
                            string="Suspend"
                            type="object"
                            class="btn-danger"
                            invisible="state != 'active'"
                            groups="alba_investors.group_investor_manager"/>
                    <button name="action_reactivate"
                            string="Reactivate"
                            type="object"
                            class="btn-success"
                            invisible="state != 'suspended'"
                            groups="alba_investors.group_investor_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="active,matured,withdrawn,suspended"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object"
                                name="action_accrue_monthly_interest"
                                class="oe_stat_button"
                                icon="fa-line-chart"
                                invisible="state != 'active'">
                            <div class="o_stat_info">
                                <field name="current_value" widget="monetary"/>
                                <span class="o_stat_text">Current Value</span>
                            </div>
                        </button>
                    </div>

                    <widget name="web_ribbon" title="Matured" bg_color="bg-info" invisible="state != 'matured'"/>
                    <widget name="web_ribbon" title="Suspended" bg_color="bg-danger" invisible="state != 'suspended'"/>

                    <div class="oe_title">
                        <label for="investment_number" string="Investment Account"/>
                        <h1>
                            <field name="investment_number" readonly="1"/>
                        </h1>
                        <div class="o_row">
                            <field name="is_high_yield" invisible="1"/>
                            <span class="badge text-bg-success" invisible="not is_high_yield">
                                <i class="fa fa-bolt"/> High Yield
                            </span>
                        </div>
                    </div>

                    <!-- ── Investment Snapshot Dashboard ────────────────── -->
                    <div class="row mt-4 mb-4 border rounded p-3 bg-light mx-0 shadow-sm">
                        <div class="col-md-4 border-end text-center">
                            <div class="text-muted small text-uppercase">Initial Investment</div>
                            <div class="h4 mb-0 fw-bold"><field name="principal_amount" widget="monetary"/></div>
                        </div>
                        <div class="col-md-4 border-end text-center text-success">
                            <div class="text-muted small text-uppercase">Total Accrued</div>
                            <div class="h4 mb-0 fw-bold">+ <field name="total_interest_accrued" widget="monetary"/></div>
                        </div>
                        <div class="col-md-4 text-center text-primary">
                            <div class="text-muted small text-uppercase">Current Portfolio</div>
                            <div class="h4 mb-0 fw-bold"><field name="current_value" widget="monetary"/></div>
                        </div>
                    </div>

                    <group>
                        <group string="Investor &amp; Terms">
                            <field name="investor_id" options="{'no_create': False}" readonly="state != 'active'"/>
                            <field name="investment_type" widget="radio" options="{'horizontal': true}" readonly="state != 'active'"/>
                            <field name="interest_rate" readonly="state != 'active'"/>
                            <field name="compounding_frequency" readonly="state != 'active'"/>
                            <field name="investment_progress" widget="progressbar"
                                   invisible="investment_type != 'fixed_term'"/>
                        </group>
                        <group string="Timeline &amp; Progress">
                            <field name="start_date" readonly="state != 'active'"/>
                            <field name="maturity_date" 
                                   readonly="state != 'active'"
                                   invisible="investment_type != 'fixed_term'"
                                   required="investment_type == 'fixed_term'"/>
                            <field name="days_to_maturity" invisible="investment_type != 'fixed_term'"/>
                            <field name="maturity_progress" widget="progressbar" string="Maturity Progress"
                                   invisible="investment_type != 'fixed_term'"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Accrual History" name="accruals">
                            <field name="accrual_ids" mode="list">
                                <list string="Accruals" decoration-success="state == 'posted'" decoration-danger="state == 'reversed'">
                                    <field name="accrual_date"/>
                                    <field name="period_start"/>
                                    <field name="period_end"/>
                                    <field name="opening_balance"/>
                                    <field name="interest_amount" sum="Total Accrued"/>
                                    <field name="closing_balance"/>
                                    <field name="state" widget="badge" decoration-success="state == 'posted'"/>
                                </list>
                            </field>
                        </page>
                        <page string="Accounting" name="accounting" groups="account.group_account_manager">
                            <group>
                                <group string="Ledger Accounts">
                                    <field name="account_interest_expense_id" options="{'no_create': True}"/>
                                    <field name="account_interest_payable_id" options="{'no_create': True}"/>
                                    <field name="account_investment_liability_id" options="{'no_create': True}"/>
                                </group>
                                <group string="Configuration">
                                    <field name="journal_id" options="{'no_create': True}"/>
                                </group>
                            </group>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" nolabel="1" placeholder="Internal notes…"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ================================================================
         alba.investment — List View
         ================================================================ -->
    <record id="view_alba_investment_list" model="ir.ui.view">
        <field name="name">alba.investment.list</field>
        <field name="model">alba.investment</field>
        <field name="arch" type="xml">
            <list string="Investments"
                  decoration-success="state == 'active'"
                  decoration-warning="state == 'suspended'"
                  decoration-muted="state in ('matured','withdrawn')">
                <field name="investment_number"/>
                <field name="investor_id"/>
                <field name="investment_type" widget="badge" decoration-info="investment_type == 'fixed_term'"/>
                <field name="principal_amount" sum="Total Principal"/>
                <field name="interest_rate" string="Rate (%)"/>
                <field name="total_interest_accrued" sum="Total Accrued"/>
                <field name="current_value" sum="Grand Portfolio"/>
                <field name="maturity_date" widget="remaining_days" invisible="investment_type != 'fixed_term'"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-warning="state == 'suspended'"
                       decoration-muted="state in ('matured','withdrawn')"/>
            </list>
        </field>
    </record>

    <!-- ================================================================
         alba.investment — Kanban View
         ================================================================ -->
    <record id="view_alba_investment_kanban" model="ir.ui.view">
        <field name="name">alba.investment.kanban</field>
        <field name="model">alba.investment</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column" sample="1">
                <field name="investment_number"/>
                <field name="investor_id"/>
                <field name="investment_type"/>
                <field name="principal_amount"/>
                <field name="current_value"/>
                <field name="interest_rate"/>
                <field name="maturity_progress"/>
                <field name="state"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title h5 mb-1">
                                        <field name="investment_number"/>
                                    </strong>
                                    <span class="text-muted small">
                                        <field name="investor_id"/>
                                    </span>
                                </div>
                            </div>
                            <div class="o_kanban_record_body my-2">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="text-muted">Principal</span>
                                    <span class="fw-bold"><field name="principal_amount" widget="monetary"/></span>
                                </div>
                                <div class="d-flex justify-content-between mb-1 text-primary">
                                    <span class="small">Current Value</span>
                                    <span class="fw-bold"><field name="current_value" widget="monetary"/></span>
                                </div>
                                <div class="mt-2" t-if="record.investment_type.raw_value == 'fixed_term'">
                                    <div class="text-muted small mb-1">Maturity Progress</div>
                                    <field name="maturity_progress" widget="progressbar"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <span class="badge rounded-pill text-bg-info">
                                        <field name="interest_rate"/>%
                                    </span>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="investment_type" widget="label_selection" options="{'classes': {'fixed_term': 'info', 'open_ended': 'success'}}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ================================================================
         alba.investment — Search View
         ================================================================ -->
    <record id="view_alba_investment_search" model="ir.ui.view">
        <field name="name">alba.investment.search</field>
        <field name="model">alba.investment</field>
        <field name="arch" type="xml">
            <search>
                <field name="investment_number"/>
                <field name="investor_id"/>
                <separator/>
                <filter string="Active"    name="active"    domain="[('state','=','active')]"/>
                <filter string="Matured"   name="matured"   domain="[('state','=','matured')]"/>
                <filter string="Suspended" name="suspended" domain="[('state','=','suspended')]"/>
                <separator/>
                <filter string="High Yield (>= 15%)" name="high_yield" domain="[('is_high_yield','=',True)]"/>
                <filter string="Fixed Term" name="fixed_term" domain="[('investment_type','=','fixed_term')]"/>
                <separator/>
                <filter string="Maturing This Month" name="maturing_this_month"
                        domain="[('maturity_date','&gt;=', (context_today()).strftime('%Y-%m-01')), ('maturity_date','&lt;=', (context_today() + relativedelta(day=31)).strftime('%Y-%m-%d'))]"/>
                <group>
                    <filter string="Investor" name="group_investor" context="{'group_by': 'investor_id'}"/>
                    <filter string="Type" name="group_type" context="{'group_by': 'investment_type'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_alba_investment" model="ir.actions.act_window">
        <field name="name">Investments</field>
        <field name="res_model">alba.investment</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

</data>
</odoo>
