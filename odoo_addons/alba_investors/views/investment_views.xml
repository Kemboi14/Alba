<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

    <!-- ================================================================
         alba.investment — Form View
         ================================================================ -->
    <record id="view_alba_investment_form" model="ir.ui.view">
        <field name="name">alba.investment.form</field>
        <field name="model">alba.investment</field>
        <field name="arch" type="xml">
            <form string="Investment Account">
                <header>
                    <button name="action_accrue_monthly_interest"
                            string="Accrue Monthly Interest"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'active'"
                            groups="alba_investors.group_investor_officer"/>
                    <button name="action_mature"
                            string="Mark as Matured"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'active'"
                            groups="alba_investors.group_investor_manager"/>
                    <button name="action_withdraw"
                            string="Mark as Withdrawn"
                            type="object"
                            class="btn-warning"
                            invisible="state not in ('active','matured')"
                            groups="alba_investors.group_investor_manager"/>
                    <button name="action_suspend"
                            string="Suspend"
                            type="object"
                            class="btn-danger"
                            invisible="state != 'active'"
                            groups="alba_investors.group_investor_manager"/>
                    <button name="action_reactivate"
                            string="Reactivate"
                            type="object"
                            class="btn-success"
                            invisible="state != 'suspended'"
                            groups="alba_investors.group_investor_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="active,matured,withdrawn,suspended"/>
                </header>

                <sheet>
                    <!-- Smart Buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button type="object"
                                name="action_accrue_monthly_interest"
                                class="oe_stat_button"
                                icon="fa-percent">
                            <field name="accrual_count"
                                   widget="statinfo"
                                   string="Accruals"/>
                        </button>
                        <button type="object"
                                name="action_view_statements"
                                class="oe_stat_button"
                                icon="fa-file-text-o">
                            <field name="statement_count"
                                   widget="statinfo"
                                   string="Statements"/>
                        </button>
                        <button type="object"
                                name="action_accrue_monthly_interest"
                                class="oe_stat_button"
                                icon="fa-line-chart"
                                invisible="state != 'active'">
                            <div class="o_stat_info">
                                <field name="current_value" widget="monetary"/>
                                <span class="o_stat_text">Current Value</span>
                            </div>
                        </button>
                    </div>

                    <!-- Status banners -->
                    <div class="alert alert-warning" role="alert"
                         invisible="state != 'suspended'">
                        <strong>This investment is suspended.</strong>
                        Interest accrual is paused until reactivated.
                    </div>
                    <div class="alert alert-info" role="alert"
                         invisible="state != 'matured'">
                        <strong>This investment has matured.</strong>
                    </div>
                    <div class="alert alert-secondary" role="alert"
                         invisible="state != 'withdrawn'">
                        <strong>This investment has been withdrawn.</strong>
                    </div>

                    <div class="oe_title">
                        <label for="investment_number" string="Investment Account"/>
                        <h1>
                            <field name="investment_number" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Investment Details">
                            <field name="investor_id"
                                   options="{'no_create': False}"
                                   readonly="state != 'active'"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="investment_type" readonly="state != 'active'"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="principal_amount" readonly="state != 'active'"/>
                        </group>
                        <group string="Interest Configuration">
                            <field name="interest_rate" readonly="state != 'active'"/>
                            <field name="compounding_frequency" readonly="state != 'active'"/>
                            <field name="start_date" readonly="state != 'active'"/>
                            <field name="maturity_date"
                                   readonly="state != 'active'"
                                   required="investment_type == 'fixed_term'"/>
                        </group>
                    </group>

                    <group string="Portfolio Value" col="4">
                        <field name="total_interest_accrued" readonly="1"/>
                        <field name="total_interest_paid"    readonly="1"/>
                        <field name="current_value"          readonly="1"/>
                    </group>

                    <notebook>

                        <!-- ── Interest Accruals ──────────────────────────── -->
                        <page string="Interest Accruals" name="accruals">
                            <field name="accrual_ids"
                                   mode="list"
                                   context="{'default_investment_id': active_id}">
                                <list string="Accruals"
                                      decoration-success="state == 'posted'"
                                      decoration-danger="state == 'reversed'"
                                      decoration-muted="state == 'draft'">
                                    <field name="accrual_date"/>
                                    <field name="period_start"/>
                                    <field name="period_end"/>
                                    <field name="opening_balance"/>
                                    <field name="interest_amount"/>
                                    <field name="closing_balance"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'posted'"
                                           decoration-danger="state == 'reversed'"
                                           decoration-muted="state == 'draft'"/>
                                    <field name="move_id" optional="hide"
                                           groups="account.group_account_user"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>

                        <!-- ── Statements ─────────────────────────────────── -->
                        <page string="Statements" name="statements">
                            <field name="statement_ids"
                                   mode="list"
                                   context="{'default_investment_id': active_id}">
                                <list string="Statements"
                                      decoration-success="state == 'sent'"
                                      decoration-info="state == 'confirmed'"
                                      decoration-muted="state == 'draft'">
                                    <field name="reference"/>
                                    <field name="statement_date"/>
                                    <field name="period_start"/>
                                    <field name="period_end"/>
                                    <field name="opening_balance"/>
                                    <field name="interest_accrued"/>
                                    <field name="closing_balance"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'sent'"
                                           decoration-info="state == 'confirmed'"
                                           decoration-muted="state == 'draft'"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>

                        <!-- ── Accounting ─────────────────────────────────── -->
                        <page string="Accounting" name="accounting"
                              groups="account.group_account_manager">
                            <group>
                                <group string="Accrual Accounts">
                                    <field name="account_interest_expense_id"
                                           options="{'no_create': True}"/>
                                    <field name="account_interest_payable_id"
                                           options="{'no_create': True}"/>
                                    <field name="account_investment_liability_id"
                                           options="{'no_create': True}"/>
                                </group>
                                <group string="Journal">
                                    <field name="journal_id"
                                           options="{'no_create': True}"/>
                                    <field name="company_id"
                                           groups="base.group_multi_company"
                                           readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <!-- ── Notes ─────────────────────────────────────── -->
                        <page string="Notes" name="notes">
                            <field name="notes"
                                   nolabel="1"
                                   placeholder="Internal notes about this investment…"/>
                        </page>

                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <!-- ================================================================
         alba.investment — List View
         ================================================================ -->
    <record id="view_alba_investment_list" model="ir.ui.view">
        <field name="name">alba.investment.list</field>
        <field name="model">alba.investment</field>
        <field name="arch" type="xml">
            <list string="Investments"
                  decoration-success="state == 'active'"
                  decoration-warning="state == 'suspended'"
                  decoration-muted="state in ('matured','withdrawn')">
                <field name="investment_number"/>
                <field name="investor_id"/>
                <field name="investment_type"/>
                <field name="principal_amount"/>
                <field name="interest_rate" string="Rate (% p.a.)"/>
                <field name="compounding_frequency"/>
                <field name="start_date"/>
                <field name="maturity_date"/>
                <field name="total_interest_accrued"/>
                <field name="current_value"/>
                <field name="accrual_count" string="Accruals"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-warning="state == 'suspended'"
                       decoration-muted="state in ('matured','withdrawn')"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ================================================================
         alba.investment — Kanban View
         ================================================================ -->
    <record id="view_alba_investment_kanban" model="ir.ui.view">
        <field name="name">alba.investment.kanban</field>
        <field name="model">alba.investment</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="investment_number"/>
                <field name="investor_id"/>
                <field name="investment_type"/>
                <field name="principal_amount"/>
                <field name="current_value"/>
                <field name="interest_rate"/>
                <field name="state"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="investment_number"/>
                                    </strong>
                                    <small class="o_kanban_record_subtitle text-muted">
                                        <field name="investor_id"/>
                                    </small>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div>
                                    <i class="fa fa-tag me-1"/>
                                    <field name="investment_type"/>
                                </div>
                                <div>Principal:
                                    <strong>
                                        <field name="principal_amount" widget="monetary"/>
                                    </strong>
                                </div>
                                <div>Current Value:
                                    <strong>
                                        <field name="current_value" widget="monetary"/>
                                    </strong>
                                </div>
                                <div>Rate: <field name="interest_rate"/>% p.a.</div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ================================================================
         alba.investment — Search View
         ================================================================ -->
    <record id="view_alba_investment_search" model="ir.ui.view">
        <field name="name">alba.investment.search</field>
        <field name="model">alba.investment</field>
        <field name="arch" type="xml">
            <search string="Search Investments">
                <field name="investment_number" string="Investment #"/>
                <field name="investor_id"       string="Investor"/>
                <separator/>
                <filter string="Active"
                        name="active"
                        domain="[('state','=','active')]"/>
                <filter string="Matured"
                        name="matured"
                        domain="[('state','=','matured')]"/>
                <filter string="Withdrawn"
                        name="withdrawn"
                        domain="[('state','=','withdrawn')]"/>
                <filter string="Suspended"
                        name="suspended"
                        domain="[('state','=','suspended')]"/>
                <separator/>
                <filter string="Fixed Term"
                        name="fixed_term"
                        domain="[('investment_type','=','fixed_term')]"/>
                <filter string="Open Ended"
                        name="open_ended"
                        domain="[('investment_type','=','open_ended')]"/>
                <separator/>
                <filter string="Maturing This Month"
                        name="maturing_this_month"
                        domain="[
                            ('maturity_date','&gt;=',(context_today().replace(day=1)).strftime('%Y-%m-%d')),
                            ('maturity_date','&lt;=',(context_today().replace(day=28)).strftime('%Y-%m-%d')),
                            ('state','=','active')
                        ]"/>
                <group expand="0" string="Group By">
                    <filter string="Status"
                            name="grp_state"
                            context="{'group_by':'state'}"/>
                    <filter string="Investor"
                            name="grp_investor"
                            context="{'group_by':'investor_id'}"/>
                    <filter string="Investment Type"
                            name="grp_type"
                            context="{'group_by':'investment_type'}"/>
                    <filter string="Compounding Frequency"
                            name="grp_frequency"
                            context="{'group_by':'compounding_frequency'}"/>
                    <filter string="Start Date"
                            name="grp_start"
                            context="{'group_by':'start_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================================================================
         alba.investment — Action Window
         ================================================================ -->
    <record id="action_alba_investment" model="ir.actions.act_window">
        <field name="name">Investments</field>
        <field name="res_model">alba.investment</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_alba_investment_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No investment accounts yet.
            </p>
            <p>
                Create investment accounts for each investor.
                Monthly compound interest is accrued automatically
                by the scheduled cron job on the 1st of each month.
            </p>
        </field>
    </record>

    <!-- ================================================================
         alba.interest.accrual — List View (standalone)
         ================================================================ -->
    <record id="view_alba_interest_accrual_list" model="ir.ui.view">
        <field name="name">alba.interest.accrual.list</field>
        <field name="model">alba.interest.accrual</field>
        <field name="arch" type="xml">
            <list string="Interest Accruals"
                  decoration-success="state == 'posted'"
                  decoration-danger="state == 'reversed'"
                  decoration-muted="state == 'draft'">
                <field name="display_name" string="Reference"/>
                <field name="investor_id"/>
                <field name="investment_id"/>
                <field name="accrual_date"/>
                <field name="period_start"/>
                <field name="period_end"/>
                <field name="opening_balance"/>
                <field name="interest_amount"/>
                <field name="closing_balance"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'posted'"
                       decoration-danger="state == 'reversed'"
                       decoration-muted="state == 'draft'"/>
                <field name="move_id" optional="hide"
                       groups="account.group_account_user"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- alba.interest.accrual — Search View -->
    <record id="view_alba_interest_accrual_search" model="ir.ui.view">
        <field name="name">alba.interest.accrual.search</field>
        <field name="model">alba.interest.accrual</field>
        <field name="arch" type="xml">
            <search string="Search Accruals">
                <field name="investor_id"   string="Investor"/>
                <field name="investment_id" string="Investment #"/>
                <separator/>
                <filter string="Draft"    name="draft"    domain="[('state','=','draft')]"/>
                <filter string="Posted"   name="posted"   domain="[('state','=','posted')]"/>
                <filter string="Reversed" name="reversed" domain="[('state','=','reversed')]"/>
                <separator/>
                <filter string="This Month"
                        name="this_month"
                        domain="[('accrual_date','&gt;=',(context_today().replace(day=1)).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Investor"    name="grp_investor"   context="{'group_by':'investor_id'}"/>
                    <filter string="Investment"  name="grp_investment" context="{'group_by':'investment_id'}"/>
                    <filter string="Status"      name="grp_state"      context="{'group_by':'state'}"/>
                    <filter string="Accrual Date" name="grp_date"      context="{'group_by':'accrual_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================================================================
         alba.interest.accrual — Action Window (defined after views for reference)
         ================================================================ -->
    <record id="action_alba_interest_accrual" model="ir.actions.act_window">
        <field name="name">Interest Accruals</field>
        <field name="res_model">alba.interest.accrual</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_alba_interest_accrual_search"/>
        <field name="context">{'search_default_posted': 1}</field>
    </record>

</data>
</odoo>
