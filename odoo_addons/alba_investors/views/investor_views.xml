<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

    <!-- ================================================================
         alba.investor — Form View
         ================================================================ -->
    <record id="view_alba_investor_form" model="ir.ui.view">
        <field name="name">alba.investor.form</field>
        <field name="model">alba.investor</field>
        <field name="arch" type="xml">
            <form string="Investor">
                <header>
                    <button name="action_auto_verify_kyc"
                            string="Auto-Verify KYC (API)"
                            type="object"
                            class="btn-primary"
                            invisible="kyc_status == 'verified'"/>
                    <button name="action_verify_kyc"
                            string="Verify Manually"
                            type="object"
                            class="btn-secondary"
                            invisible="kyc_status == 'verified'"
                            groups="alba_investors.group_investor_officer"/>
                    <button name="action_suspend"
                            string="Suspend"
                            type="object"
                            class="btn-warning"
                            invisible="state != 'active'"
                            groups="alba_investors.group_investor_manager"/>
                    <button name="action_activate"
                            string="Reactivate"
                            type="object"
                            class="btn-success"
                            invisible="state != 'suspended'"
                            groups="alba_investors.group_investor_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="active,suspended,blacklisted"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_investments"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-line-chart">
                            <field name="active_investment_count"
                                   widget="statinfo"
                                   string="Active Investments"/>
                        </button>
                        <button name="action_view_statements"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-file-text-o">
                            <div class="o_stat_info">
                                <field name="current_portfolio_value" widget="monetary"/>
                                <span class="o_stat_text">Portfolio Value</span>
                            </div>
                        </button>
                    </div>

                    <widget name="web_ribbon" title="Blacklisted" bg_color="bg-danger" invisible="state != 'blacklisted'"/>
                    <widget name="web_ribbon" title="Suspended" bg_color="bg-warning" invisible="state != 'suspended'"/>
                    <widget name="web_ribbon" title="Verified" bg_color="bg-success" invisible="kyc_status != 'verified'"/>

                    <div class="oe_title">
                        <label for="partner_id" string="Investor"/>
                        <h1>
                            <field name="partner_id"
                                   options="{'no_create': False}"
                                   placeholder="Select or create a contact…"/>
                        </h1>
                        <div class="o_row">
                            <field name="investor_number" readonly="1" class="text-muted"/>
                            <field name="is_high_value" invisible="1"/>
                            <span class="badge text-bg-warning rounded-pill" invisible="not is_high_value">
                                <i class="fa fa-star"/> High Value
                            </span>
                        </div>
                    </div>

                    <!-- ── Portfolio Snapshot Dashboard ────────────────── -->
                    <div class="row mt-4 mb-4 border rounded p-3 bg-light mx-0 shadow-sm">
                        <div class="col-md-3 border-end text-center">
                            <div class="text-muted small text-uppercase">Principal Invested</div>
                            <div class="h4 mb-0 fw-bold"><field name="total_invested" widget="monetary"/></div>
                        </div>
                        <div class="col-md-3 border-end text-center text-success">
                            <div class="text-muted small text-uppercase">Interest Earned</div>
                            <div class="h4 mb-0 fw-bold">+ <field name="total_interest_earned" widget="monetary"/></div>
                        </div>
                        <div class="col-md-3 border-end text-center text-primary">
                            <div class="text-muted small text-uppercase">Current Portfolio</div>
                            <div class="h4 mb-0 fw-bold"><field name="current_portfolio_value" widget="monetary"/></div>
                        </div>
                        <div class="col-md-3 text-center text-info">
                            <div class="text-muted small text-uppercase">Total Paid Out</div>
                            <div class="h4 mb-0 fw-bold"><field name="total_interest_paid_out" widget="monetary"/></div>
                        </div>
                    </div>

                    <group>
                        <group string="Identity">
                            <field name="id_type"/>
                            <field name="id_number"/>
                            <field name="date_of_birth"/>
                            <field name="age" readonly="1"/>
                            <field name="gender"/>
                            <field name="nationality"/>
                        </group>
                        <group string="Portal Integration" groups="base.group_no_one">
                            <field name="django_investor_id" readonly="1"/>
                            <div colspan="2" class="alert alert-info py-1 small">
                                <i class="fa fa-refresh"/> Linked to Django Portal Account
                            </div>
                        </group>
                        <group string="KYC &amp; Lifecycle">
                            <field name="kyc_status" widget="badge"
                                   decoration-success="kyc_status == 'verified'"
                                   decoration-warning="kyc_status in ('partial','complete')"
                                   decoration-danger="kyc_status == 'rejected'"
                                   decoration-info="kyc_status == 'pending'"/>
                            <field name="kyc_progress" widget="progressbar" string="KYC Progress"/>
                            <field name="kyc_verified_by" readonly="1" invisible="kyc_status != 'verified'"/>
                            <field name="kyc_verified_date" readonly="1" invisible="kyc_status != 'verified'"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Payout Details" name="payout">
                            <group>
                                <group string="Bank Account">
                                    <field name="bank_name"/>
                                    <field name="bank_account_number"/>
                                    <field name="bank_branch"/>
                                </group>
                                <group string="Mobile Money &amp; Preference">
                                    <field name="mpesa_number"/>
                                    <field name="preferred_payment_method"/>
                                </group>
                            </group>
                        </page>

                        <page string="Investments" name="investments">
                            <field name="investment_ids" mode="list">
                                <list string="Investments"
                                      decoration-success="state == 'active'"
                                      decoration-muted="state in ('matured','withdrawn')"
                                      decoration-warning="state == 'suspended'">
                                    <field name="investment_number"/>
                                    <field name="investment_type"/>
                                    <field name="principal_amount" sum="Total Principal"/>
                                    <field name="interest_rate" string="Rate (%)"/>
                                    <field name="start_date"/>
                                    <field name="maturity_date"/>
                                    <field name="current_value" sum="Total Value"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'active'"
                                           decoration-muted="state in ('matured','withdrawn')"
                                           decoration-warning="state == 'suspended'"/>
                                </list>
                            </field>
                        </page>

                        <page string="Notes" name="notes">
                            <field name="notes" nolabel="1" placeholder="Internal notes about this investor…"/>
                        </page>
                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <!-- ================================================================
         alba.investor — List View
         ================================================================ -->
    <record id="view_alba_investor_list" model="ir.ui.view">
        <field name="name">alba.investor.list</field>
        <field name="model">alba.investor</field>
        <field name="arch" type="xml">
            <list string="Investors"
                  decoration-danger="state == 'blacklisted'"
                  decoration-warning="state == 'suspended'"
                  decoration-muted="active == False">
                <field name="investor_number"/>
                <field name="partner_id" string="Name"/>
                <field name="kyc_status" widget="badge"
                       decoration-success="kyc_status == 'verified'"
                       decoration-warning="kyc_status in ('partial','complete')"
                       decoration-danger="kyc_status == 'rejected'"
                       decoration-info="kyc_status == 'pending'"/>
                <field name="active_investment_count" string="Investments"/>
                <field name="total_invested" sum="Grand Total Invested"/>
                <field name="current_portfolio_value" sum="Grand Portfolio Value"/>
                <field name="preferred_payment_method"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-warning="state == 'suspended'"
                       decoration-danger="state == 'blacklisted'"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ================================================================
         alba.investor — Kanban View
         ================================================================ -->
    <record id="view_alba_investor_kanban" model="ir.ui.view">
        <field name="name">alba.investor.kanban</field>
        <field name="model">alba.investor</field>
        <field name="arch" type="xml">
            <kanban default_group_by="kyc_status" class="o_kanban_small_column" sample="1">
                <field name="investor_number"/>
                <field name="partner_id"/>
                <field name="kyc_status"/>
                <field name="state"/>
                <field name="kyc_progress"/>
                <field name="is_high_value"/>
                <field name="active_investment_count"/>
                <field name="current_portfolio_value"/>
                <field name="currency_id"/>
                <field name="preferred_payment_method"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title h5 mb-1">
                                        <field name="partner_id"/>
                                    </strong>
                                    <span class="badge text-bg-warning mb-2" invisible="not is_high_value">
                                        <i class="fa fa-star" title="High Value"/> High Value
                                    </span>
                                </div>
                                <div class="o_dropdown_kanban dropdown">
                                    <a class="dropdown-toggle o-no-caret btn" role="button" data-bs-toggle="dropdown" href="#" aria-label="Settings" title="Settings">
                                        <span class="fa fa-ellipsis-v"/>
                                    </a>
                                    <div class="dropdown-menu" role="menu">
                                        <a type="object" name="action_view_investments" class="dropdown-item">Investments</a>
                                        <a type="object" name="action_view_statements" class="dropdown-item">Statements</a>
                                    </div>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div class="row small text-muted mb-2">
                                    <div class="col-6">
                                        <i class="fa fa-hashtag" title="Investor #"/> <field name="investor_number"/>
                                    </div>
                                    <div class="col-6 text-end">
                                        <i class="fa fa-credit-card" title="Payment Method"/> <field name="preferred_payment_method"/>
                                    </div>
                                </div>
                                <div class="d-flex justify-content-between align-items-end">
                                    <div>
                                        <div class="text-muted small">Portfolio</div>
                                        <div class="h5 mb-0 text-primary fw-bold">
                                            <field name="current_portfolio_value" widget="monetary"/>
                                        </div>
                                    </div>
                                    <div class="text-end">
                                        <span class="badge rounded-pill text-bg-info">
                                            <field name="active_investment_count"/> Active
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom mt-3">
                                <div class="w-100">
                                    <div class="text-muted small mb-1">KYC Completion</div>
                                    <field name="kyc_progress" widget="progressbar"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ================================================================
         alba.investor — Search View
         ================================================================ -->
    <record id="view_alba_investor_search" model="ir.ui.view">
        <field name="name">alba.investor.search</field>
        <field name="model">alba.investor</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <field name="investor_number"/>
                <field name="id_number"/>
                <separator/>
                <filter string="KYC Pending"  name="kyc_pending"  domain="[('kyc_status','=','pending')]"/>
                <filter string="KYC Verified" name="kyc_verified" domain="[('kyc_status','=','verified')]"/>
                <separator/>
                <filter string="Active"       name="active"       domain="[('state','=','active')]"/>
                <filter string="Suspended"    name="suspended"    domain="[('state','=','suspended')]"/>
                <separator/>
                <filter string="High Value (> 1M)" name="high_value" domain="[('is_high_value','=',True)]"/>
                <filter string="M-Pesa Preferred"  name="mpesa_payout" domain="[('preferred_payment_method','=','mpesa')]"/>
                <separator/>
                <group>
                    <filter string="Nationality" name="group_nationality" context="{'group_by': 'nationality'}"/>
                    <filter string="Payout Method" name="group_payout" context="{'group_by': 'preferred_payment_method'}"/>
                    <filter string="KYC Status" name="group_kyc" context="{'group_by': 'kyc_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_alba_investor" model="ir.actions.act_window">
        <field name="name">Investors</field>
        <field name="res_model">alba.investor</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No investors yet — add your first one!</p>
        </field>
    </record>

</data>
</odoo>
