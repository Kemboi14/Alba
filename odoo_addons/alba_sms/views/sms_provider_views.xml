<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================== -->
    <!--  Form view — alba.sms.provider                                     -->
    <!-- ================================================================== -->
    <record id="view_alba_sms_provider_form" model="ir.ui.view">
        <field name="name">alba.sms.provider.form</field>
        <field name="model">alba.sms.provider</field>
        <field name="arch" type="xml">
            <form string="SMS Provider">

                <header>
                    <button
                        name="action_test_connection"
                        string="Test Connection"
                        type="object"
                        class="btn-secondary"
                        icon="fa-plug"
                        groups="alba_sms.group_sms_admin"
                    />
                </header>

                <sheet>

                    <!-- ── Smart buttons ─────────────────────────────── -->
                    <div class="oe_button_box" name="button_box">
                        <button
                            name="action_view_logs"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-list-alt"
                        >
                            <field
                                name="log_count"
                                widget="statinfo"
                                string="SMS Logs"
                            />
                        </button>
                    </div>

                    <!-- ── Title ─────────────────────────────────────── -->
                    <div class="oe_title">
                        <label for="name" string="Provider Name" class="oe_edit_only"/>
                        <h1>
                            <field
                                name="name"
                                placeholder='e.g. "Africa&apos;s Talking – Production"'
                            />
                        </h1>
                    </div>

                    <!-- ── Connection Settings + Authentication ───────── -->
                    <group>

                        <group string="Connection Settings">
                            <field name="provider_type"/>
                            <field
                                name="api_url"
                                widget="url"
                                placeholder="https://api.africastalking.com/version1/messaging"
                            />
                            <field
                                name="sender_id"
                                placeholder="e.g. AlbaCapital or +254700000000"
                            />
                        </group>

                        <group string="Authentication">
                            <field name="api_key" password="True"/>
                            <field name="api_secret" password="True"/>
                            <field name="username"/>
                            <field
                                name="auth_type"
                                invisible="provider_type != 'generic_http'"
                            />
                        </group>

                    </group>

                    <!-- ── Generic HTTP Parameter Mapping ────────────── -->
                    <group
                        string="Generic HTTP Parameter Mapping"
                        invisible="provider_type != 'generic_http'"
                    >
                        <group>
                            <field name="auth_header_name"/>
                            <field name="phone_param_name"/>
                        </group>
                        <group>
                            <field name="message_param_name"/>
                        </group>
                    </group>

                    <!-- ── Operational Settings ──────────────────────── -->
                    <group>
                        <group string="Settings">
                            <field name="is_active" widget="boolean_toggle"/>
                            <field name="timeout_s"/>
                            <field
                                name="company_id"
                                groups="base.group_multi_company"
                                options="{'no_create': True}"
                            />
                        </group>
                    </group>

                    <!-- ── Notebook ──────────────────────────────────── -->
                    <notebook>

                        <page
                            string="Extra Parameters"
                            name="extra_params"
                            invisible="provider_type != 'generic_http'"
                        >
                            <p class="text-muted" style="margin-bottom: 8px;">
                                Additional key/value pairs sent with every request.
                                Must be a valid JSON object.
                            </p>
                            <field
                                name="extra_params"
                                nolabel="1"
                                widget="ace"
                                options="{'mode': 'json'}"
                                placeholder='{"channel": "sms", "type": "plain"}'
                                style="min-height: 200px; font-family: monospace;"
                            />
                        </page>

                    </notebook>

                </sheet>

            </form>
        </field>
    </record>


    <!-- ================================================================== -->
    <!--  List view — alba.sms.provider                                     -->
    <!-- ================================================================== -->
    <record id="view_alba_sms_provider_list" model="ir.ui.view">
        <field name="name">alba.sms.provider.list</field>
        <field name="model">alba.sms.provider</field>
        <field name="arch" type="xml">
            <list
                string="SMS Providers"
                decoration-muted="is_active == False"
            >
                <field name="name"/>
                <field name="provider_type"/>
                <field name="api_url" string="API Endpoint" optional="show"/>
                <field name="sender_id" string="Sender ID"/>
                <field name="is_active" string="Active" widget="boolean_toggle"/>
                <field name="log_count" string="Logs" optional="show"/>
                <field name="company_id"
                       groups="base.group_multi_company"
                       optional="hide"/>
            </list>
        </field>
    </record>


    <!-- ================================================================== -->
    <!--  Search view — alba.sms.provider                                   -->
    <!-- ================================================================== -->
    <record id="view_alba_sms_provider_search" model="ir.ui.view">
        <field name="name">alba.sms.provider.search</field>
        <field name="model">alba.sms.provider</field>
        <field name="arch" type="xml">
            <search string="Search SMS Providers">

                <!-- Full-text search fields -->
                <field name="name" string="Provider Name"/>
                <field
                    name="api_url"
                    string="API Endpoint"
                    filter_domain="[('api_url', 'ilike', self)]"
                />
                <field
                    name="sender_id"
                    string="Sender ID"
                    filter_domain="[('sender_id', 'ilike', self)]"
                />

                <!-- ── Active / Inactive filters ──────────────────── -->
                <separator/>
                <filter
                    string="Active"
                    name="filter_active"
                    domain="[('is_active', '=', True)]"
                />
                <filter
                    string="Inactive"
                    name="filter_inactive"
                    domain="[('is_active', '=', False)]"
                />

                <!-- ── Provider type shortcut filters ─────────────── -->
                <separator/>
                <filter
                    string="Africa's Talking"
                    name="filter_type_at"
                    domain="[('provider_type', '=', 'africa_talking')]"
                />
                <filter
                    string="Twilio"
                    name="filter_type_twilio"
                    domain="[('provider_type', '=', 'twilio')]"
                />
                <filter
                    string="Vonage / Nexmo"
                    name="filter_type_vonage"
                    domain="[('provider_type', '=', 'vonage')]"
                />
                <filter
                    string="Generic HTTP"
                    name="filter_type_generic"
                    domain="[('provider_type', '=', 'generic_http')]"
                />

                <!-- ── Group By ────────────────────────────────────── -->
                <separator/>
                <group expand="0" string="Group By">
                    <filter
                        string="Provider Type"
                        name="group_provider_type"
                        context="{'group_by': 'provider_type'}"
                    />
                    <filter
                        string="Company"
                        name="group_company"
                        context="{'group_by': 'company_id'}"
                        groups="base.group_multi_company"
                    />
                </group>

            </search>
        </field>
    </record>

</odoo>
