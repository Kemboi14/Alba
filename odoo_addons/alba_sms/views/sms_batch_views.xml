<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <!-- ================================================================== -->
    <!--  Kanban view — alba.sms.batch                                      -->
    <!--  Default grouped by state for a campaign pipeline dashboard        -->
    <!-- ================================================================== -->
    <record id="view_alba_sms_batch_kanban" model="ir.ui.view">
        <field name="name">alba.sms.batch.kanban</field>
        <field name="model">alba.sms.batch</field>
        <field name="arch" type="xml">
            <kanban
                string="SMS Campaigns"
                default_group_by="state"
                class="o_kanban_small_column"
                quick_create="false"
                group_create="false"
            >
                <field name="id" />
                <field name="name" />
                <field name="state" />
                <field name="template_id" />
                <field name="target_type" />
                <field name="total_count" />
                <field name="sent_count" />
                <field name="delivered_count" />
                <field name="failed_count" />
                <field name="progress_pct" />
                <field name="scheduled_at" />
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click">

                            <!-- Card header: campaign name -->
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name" />
                                    </strong>
                                </div>
                            </div>

                            <!-- Card body: template and target audience -->
                            <div class="o_kanban_record_body">
                                <div
                                    class="text-muted"
                                    style="font-size: 0.85em;"
                                >
                                    <i class="fa fa-file-text-o me-1" title="Template"/>
                                    <field name="template_id" />
                                </div>
                                <div
                                    class="text-muted"
                                    style="font-size: 0.85em; margin-top: 2px;"
                                >
                                    <i class="fa fa-users me-1" title="Target"/>
                                    <field name="target_type" />
                                </div>
                            </div>

                            <!-- Card footer: sent/total counts and scheduled time -->
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <t t-if="record.total_count.value > 0">
                                        <span
                                            class="text-muted"
                                            style="font-size: 0.85em;"
                                        >
                                            <i class="fa fa-paper-plane me-1" />
                                            <t
                                                t-esc="record.sent_count.value"
                                            />/<t
                                                t-esc="record.total_count.value"
                                            />
                                        </span>
                                        <t t-if="record.failed_count.value > 0">
                                            <span
                                                class="text-danger ms-2"
                                                style="font-size: 0.85em;"
                                            >
                                                <i class="fa fa-times me-1" />
                                                <t
                                                    t-esc="record.failed_count.value"
                                                /> failed
                                            </span>
                                        </t>
                                    </t>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <t t-if="record.scheduled_at.value">
                                        <span
                                            class="text-muted"
                                            style="font-size: 0.8em;"
                                        >
                                            <i class="fa fa-clock-o me-1" title="Scheduled"/>
                                            <field
                                                name="scheduled_at"
                                                widget="date"
                                            />
                                        </span>
                                    </t>
                                </div>
                            </div>

                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>


    <!-- ================================================================== -->
    <!--  Form view — alba.sms.batch                                        -->
    <!-- ================================================================== -->
    <record id="view_alba_sms_batch_form" model="ir.ui.view">
        <field name="name">alba.sms.batch.form</field>
        <field name="model">alba.sms.batch</field>
        <field name="arch" type="xml">
            <form string="SMS Campaign">

                <header>

                    <!-- Generate recipients — draft only -->
                    <button
                        name="action_generate_lines"
                        string="Generate Recipients"
                        type="object"
                        class="btn-primary"
                        icon="fa-users"
                        invisible="state != 'draft'"
                        help="Resolve the target audience and create one batch line per recipient."
                    />

                    <!-- Send now — draft only, officer group required -->
                    <button
                        name="action_send_now"
                        string="Send Now"
                        type="object"
                        class="btn-success"
                        icon="fa-paper-plane"
                        invisible="state != 'draft'"
                        groups="alba_sms.group_sms_officer"
                        confirm="This will immediately send SMS messages to all generated recipients. This cannot be undone. Continue?"
                    />

                    <!-- Schedule — draft only -->
                    <button
                        name="action_schedule"
                        string="Schedule"
                        type="object"
                        class="btn-secondary"
                        icon="fa-clock-o"
                        invisible="state != 'draft'"
                        help="Queue this campaign for automatic processing at the Send At time."
                    />

                    <!-- Cancel — scheduled or running only -->
                    <button
                        name="action_cancel"
                        string="Cancel"
                        type="object"
                        class="btn-danger"
                        icon="fa-times"
                        invisible="state not in ('scheduled', 'running')"
                        confirm="Cancel this campaign? Any unsent messages will be abandoned and this action cannot be reversed."
                    />

                    <field
                        name="state"
                        widget="statusbar"
                        statusbar_visible="draft,scheduled,running,done"
                    />

                </header>

                <sheet>

                    <!-- ── Stat buttons ───────────────────────────────── -->
                    <div class="oe_button_box" name="button_box">

                        <button
                            class="oe_stat_button"
                            icon="fa-users"
                            type="button"
                        >
                            <div class="o_stat_info">
                                <span class="o_stat_value">
                                    <field name="total_count" readonly="1" />
                                </span>
                                <span class="o_stat_text">Recipients</span>
                            </div>
                        </button>

                        <button
                            class="oe_stat_button"
                            icon="fa-paper-plane"
                            type="button"
                        >
                            <div class="o_stat_info">
                                <span class="o_stat_value">
                                    <field name="sent_count" readonly="1" />
                                </span>
                                <span class="o_stat_text">Sent</span>
                            </div>
                        </button>

                        <button
                            class="oe_stat_button"
                            icon="fa-check-circle"
                            type="button"
                        >
                            <div class="o_stat_info">
                                <span class="o_stat_value">
                                    <field
                                        name="delivered_count"
                                        readonly="1"
                                    />
                                </span>
                                <span class="o_stat_text">Delivered</span>
                            </div>
                        </button>

                        <button
                            class="oe_stat_button"
                            icon="fa-times-circle"
                            type="button"
                        >
                            <div class="o_stat_info">
                                <span class="o_stat_value text-danger">
                                    <field name="failed_count" readonly="1" />
                                </span>
                                <span class="o_stat_text">Failed</span>
                            </div>
                        </button>

                    </div>

                    <!-- ── Title ─────────────────────────────────────── -->
                    <div class="oe_title">
                        <label
                            for="name"
                            string="Campaign Name"
                        />
                        <h1>
                            <field
                                name="name"
                                placeholder='e.g. "March Overdue Reminder"'
                            />
                        </h1>
                    </div>

                    <!-- ── Campaign Settings + Target Audience ────────── -->
                    <group>

                        <group string="Campaign Settings">
                            <field
                                name="template_id"
                                options="{'no_create': True}"
                            />
                            <field
                                name="provider_id"
                                options="{'no_create': True}"
                            />
                            <field
                                name="state"
                                widget="badge"
                                decoration-success="state == 'done'"
                                decoration-warning="state in ('scheduled', 'running')"
                                decoration-danger="state == 'cancelled'"
                                decoration-info="state == 'draft'"
                            />
                            <field name="scheduled_at" />
                            <field
                                name="company_id"
                                groups="base.group_multi_company"
                                options="{'no_create': True}"
                            />
                        </group>

                        <group string="Target Audience">
                            <field name="target_type" />
                            <field
                                name="target_domain"
                                widget="text"
                                invisible="target_type != 'custom_domain'"
                                placeholder='[["is_active","=",true]]'
                                help="A JSON-serialised Odoo domain evaluated against alba.loan or alba.investor records."
                            />
                            <field
                                name="manual_phones"
                                widget="text"
                                invisible="target_type != 'manual_list'"
                                placeholder="+254700000001&#10;+254700000002&#10;+254700000003"
                                help="One phone number per line. Numbers are normalised to E.164 format before sending."
                            />
                        </group>

                    </group>

                    <!-- ── Progress bar ──────────────────────────────── -->
                    <group
                        string="Sending Progress"
                        invisible="total_count == 0"
                    >
                        <field
                            name="progress_pct"
                            nolabel="1"
                            widget="progressbar"
                            options="{'max_value': 100, 'editable': false}"
                        />
                    </group>

                    <!-- ── Notebook ──────────────────────────────────── -->
                    <notebook>

                        <page string="Recipients" name="recipients">
                            <!-- Helper hint shown only in draft before lines are generated -->
                            <div
                                class="alert alert-info"
                                role="alert"
                                invisible="state != 'draft' or total_count > 0"
                            >
                                <i class="fa fa-info-circle me-1" />
                                Click <b>Generate Recipients</b> to resolve the
                                target audience and populate this list before sending.
                            </div>
                            <field
                                name="batch_line_ids"
                                context="{'default_batch_id': id}"
                            >
                                <list
                                    string="Batch Lines"
                                    decoration-success="status == 'delivered'"
                                    decoration-warning="status == 'sent'"
                                    decoration-danger="status == 'failed'"
                                    create="false"
                                    delete="false"
                                >
                                    <field name="phone_number" string="Phone" />
                                    <field
                                        name="status"
                                        widget="badge"
                                        decoration-success="status == 'delivered'"
                                        decoration-warning="status == 'sent'"
                                        decoration-danger="status == 'failed'"
                                        decoration-info="status == 'queued'"
                                    />
                                    <field
                                        name="message"
                                        string="Message (preview)"
                                        optional="show"
                                    />
                                    <field
                                        name="error_message"
                                        string="Error"
                                        optional="show"
                                        class="text-danger"
                                    />
                                    <field
                                        name="res_model"
                                        string="Source Model"
                                        optional="hide"
                                    />
                                    <field
                                        name="res_id"
                                        string="Record ID"
                                        optional="hide"
                                    />
                                </list>
                            </field>
                        </page>

                    </notebook>

                </sheet>

                <!-- ── Chatter ───────────────────────────────────────── -->
                <chatter/>

            </form>
        </field>
    </record>


    <!-- ================================================================== -->
    <!--  List view — alba.sms.batch                                        -->
    <!--                                                                    -->
    <!--  decoration-danger    → red row    for cancelled campaigns         -->
    <!--  decoration-success   → green row  for completed (done) campaigns  -->
    <!--  decoration-warning   → amber row  for actively running campaigns  -->
    <!-- ================================================================== -->
    <record id="view_alba_sms_batch_list" model="ir.ui.view">
        <field name="name">alba.sms.batch.list</field>
        <field name="model">alba.sms.batch</field>
        <field name="arch" type="xml">
            <list
                string="SMS Campaigns"
                decoration-danger="state == 'cancelled'"
                decoration-success="state == 'done'"
                decoration-warning="state == 'running'"
                default_order="create_date desc"
            >
                <field name="name" />
                <field name="template_id" string="Template" optional="show" />
                <field name="target_type" string="Target" optional="show" />
                <field
                    name="state"
                    widget="badge"
                    decoration-success="state == 'done'"
                    decoration-warning="state in ('scheduled', 'running')"
                    decoration-danger="state == 'cancelled'"
                    decoration-info="state == 'draft'"
                />
                <field name="total_count" string="Total" optional="show" />
                <field name="sent_count" string="Sent" optional="show" />
                <field
                    name="failed_count"
                    string="Failed"
                    optional="show"
                    decoration-danger="failed_count > 0"
                />
                <field name="scheduled_at" string="Send At" optional="show" />
                <field name="create_date" string="Created" optional="hide" />
                <field
                    name="company_id"
                    groups="base.group_multi_company"
                    optional="hide"
                />
            </list>
        </field>
    </record>


    <!-- ================================================================== -->
    <!--  Search view — alba.sms.batch                                      -->
    <!-- ================================================================== -->
    <record id="view_alba_sms_batch_search" model="ir.ui.view">
        <field name="name">alba.sms.batch.search</field>
        <field name="model">alba.sms.batch</field>
        <field name="arch" type="xml">
            <search string="Search SMS Campaigns">

                <!-- Full-text search fields -->
                <field name="name" string="Campaign Name" />
                <field
                    name="template_id"
                    string="Template"
                    filter_domain="[('template_id.name', 'ilike', self)]"
                />
                <field
                    name="provider_id"
                    string="Provider"
                    filter_domain="[('provider_id.name', 'ilike', self)]"
                />

                <!-- ── State filters ─────────────────────────────────── -->
                <filter
                    string="Draft"
                    name="filter_draft"
                    domain="[('state', '=', 'draft')]"
                />
                <filter
                    string="Scheduled"
                    name="filter_scheduled"
                    domain="[('state', '=', 'scheduled')]"
                />
                <filter
                    string="Running"
                    name="filter_running"
                    domain="[('state', '=', 'running')]"
                />
                <filter
                    string="Completed"
                    name="filter_done"
                    domain="[('state', '=', 'done')]"
                />
                <filter
                    string="Cancelled"
                    name="filter_cancelled"
                    domain="[('state', '=', 'cancelled')]"
                />

                <!-- ── Convenience compound filters ──────────────────── -->
                <filter
                    string="Active Campaigns"
                    name="filter_active"
                    domain="[('state', 'in', ['draft', 'scheduled', 'running'])]"
                    help="Draft, scheduled, or currently running campaigns."
                />

                <!-- ── Time range filters ────────────────────────────── -->

                <filter
                    string="Created Today"
                    name="filter_today"
                    domain="[('create_date', '&gt;=', (context_today()).strftime('%Y-%m-%d'))]"
                />
                <filter
                    string="Scheduled Today"
                    name="filter_scheduled_today"
                    domain="[('scheduled_at', '&gt;=', (context_today()).strftime('%Y-%m-%d')),
                             ('scheduled_at', '&lt;',  (context_today() + datetime.timedelta(days=1)).strftime('%Y-%m-%d'))]"
                />

                <!-- ── Group By ──────────────────────────────────────── -->
                <group>
                    <filter
                        string="State"
                        name="group_state"
                        context="{'group_by': 'state'}"
                    />
                    <filter
                        string="Target Type"
                        name="group_target_type"
                        context="{'group_by': 'target_type'}"
                    />
                    <filter
                        string="Template"
                        name="group_template"
                        context="{'group_by': 'template_id'}"
                    />
                    <filter
                        string="Provider"
                        name="group_provider"
                        context="{'group_by': 'provider_id'}"
                    />
                </group>

            </search>
        </field>
    </record>

</odoo>
