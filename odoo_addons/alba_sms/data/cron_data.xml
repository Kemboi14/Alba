<?xml version="1.0" encoding="utf-8" ?>
<odoo>
<data noupdate="1">

    <!-- ================================================================
         Cron: Process Scheduled SMS Batches (every 15 minutes)
         Picks up all alba.sms.batch records in state='scheduled' whose
         scheduled_at has passed and dispatches them in pages of 100.
         Also continues any batch already in state='running' that still
         has queued lines.
         ================================================================ -->
    <record id="ir_cron_alba_sms_process_batches" model="ir.cron">
        <field
                name="name"
            >Alba SMS — Process Scheduled Batches (Every 15 min)</field>
        <field name="model_id" ref="alba_sms.model_alba_sms_batch" />
        <field name="state">code</field>
        <field name="code">
env['alba.sms.batch'].cron_process_scheduled_batches()
        </field>
        <field name="user_id" ref="base.user_root" />
        <field name="interval_number">15</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
        <field name="priority">20</field>
    </record>

    <!-- ================================================================
         System Parameter: Global SMS enabled flag
         Set value to 0 in Settings > Technical > Parameters > System
         Parameters to temporarily suspend all outbound SMS dispatching
         without uninstalling the module.
         ================================================================ -->
    <record id="param_alba_sms_enabled" model="ir.config_parameter">
        <field name="key">alba_sms.enabled</field>
        <field name="value">1</field>
    </record>

    <record id="ir_cron_alba_sms_pre_due_reminders" model="ir.cron">
        <field name="name">Alba SMS — Daily Repayment Reminders (3 Days Before)</field>
        <field name="model_id" ref="alba_loans.model_alba_loan" />
        <field name="state">code</field>
        <field name="code">env['alba.loan'].cron_send_pre_due_reminders()</field>
        <field name="user_id" ref="base.user_root" />
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
        <field name="priority">25</field>
    </record>

    </data>
</odoo>
