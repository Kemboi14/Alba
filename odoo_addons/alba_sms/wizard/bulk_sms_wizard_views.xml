<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>

        <!-- ================================================================
             Bulk SMS Wizard — Form View
             ================================================================ -->
        <record id="view_alba_sms_wizard_form" model="ir.ui.view">
            <field name="name">alba.sms.wizard.form</field>
            <field name="model">alba.sms.wizard</field>
            <field name="arch" type="xml">
                <form string="Send SMS">

                    <sheet>

                        <!-- ── Message configuration ─────────────────────── -->
                        <group string="Message Settings">
                            <group>
                                <field
                                    name="template_id"
                                    options="{'no_create': True, 'no_open': True}"
                                />
                                <field
                                    name="provider_id"
                                    options="{'no_create': True, 'no_open': True}"
                                />
                            </group>
                            <group
                                string="Custom Message"
                                help="Overrides the template for this dispatch only. Leave blank to use the selected template."
                            >
                                <field
                                    name="custom_message"
                                    nolabel="1"
                                    colspan="2"
                                    placeholder="Leave blank to use the selected template…"
                                />
                            </group>
                        </group>

                        <!-- ── Preview trigger ───────────────────────────── -->
                        <div class="o_row mb-3">
                            <button
                                name="action_preview"
                                string="&#128269; Preview Recipients"
                                type="object"
                                class="btn-secondary"
                            />
                            <span
                                class="ms-2 text-muted small"
                                invisible="preview_line_ids != []"
                            >
                                Click Preview to load recipients and render messages before sending.
                            </span>
                        </div>

                        <!-- ── Recipient preview lines ───────────────────── -->
                        <notebook>
                            <page string="Recipients" name="page_recipients">
                                <field name="preview_line_ids" nolabel="1">
                                    <list
                                        editable="bottom"
                                        decoration-muted="not phone_number"
                                        decoration-warning="not phone_number"
                                    >
                                        <field
                                            name="send"
                                            widget="boolean_toggle"
                                            string="Send?"
                                        />
                                        <field
                                            name="recipient_name"
                                            string="Recipient"
                                            readonly="1"
                                        />
                                        <field
                                            name="phone_number"
                                            string="Phone Number"
                                        />
                                        <field
                                            name="message"
                                            string="Message"
                                            optional="show"
                                        />
                                        <field
                                            name="res_id"
                                            column_invisible="1"
                                        />
                                    </list>
                                </field>
                            </page>
                        </notebook>

                        <!-- ── Internal context fields (hidden) ─────────── -->
                        <field name="res_model" invisible="1" />
                        <field name="res_ids" invisible="1" />

                    </sheet>

                    <footer>
                        <button
                            name="action_send"
                            string="Send SMS"
                            type="object"
                            class="btn-primary"
                            data-hotkey="v"
                            confirm="Send SMS to all checked recipients? This cannot be undone."
                        />
                        <button
                            string="Cancel"
                            class="btn-secondary"
                            special="cancel"
                            data-hotkey="z"
                        />
                    </footer>

                </form>
            </field>
        </record>

        <!-- ================================================================
             Bulk SMS Wizard — Window Action
             (Referenced by server actions bound to loan / investor lists)
             ================================================================ -->
        <record id="action_alba_sms_wizard" model="ir.actions.act_window">
            <field name="name">Send SMS</field>
            <field name="res_model">alba.sms.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

    </data>
</odoo>
