<?xml version="1.0" encoding="utf-8" ?>
<odoo>
<data>

    <!-- ================================================================
         alba.sync.log — Form View
         ================================================================ -->
    <record id="view_alba_sync_log_form" model="ir.ui.view">
        <field name="name">alba.sync.log.form</field>
        <field name="model">alba.sync.log</field>
        <field name="arch" type="xml">
            <form string="Sync Log Entry" create="false" edit="false">
                <sheet>

                    <!-- Status banner -->
                    <div
                        class="alert alert-success"
                        role="alert"
                        invisible="status != 'success'"
                    >
                        <i class="fa fa-check-circle me-1" title="Success"/>
                        <strong>Sync successful.</strong>
                    </div>
                    <div
                        class="alert alert-warning"
                        role="alert"
                        invisible="status != 'partial'"
                    >
                        <i class="fa fa-exclamation-triangle me-1" title="Warning"/>
                        <strong>Partial success</strong> — some data may not have synced correctly.
                        Review the detail field below.
                    </div>
                    <div
                        class="alert alert-danger"
                        role="alert"
                        invisible="status != 'failure'"
                    >
                        <i class="fa fa-times-circle me-1" title="Error"/>
                        <strong>Sync failed.</strong> See the detail and payload sections below.
                    </div>
                    <div
                        class="alert alert-info"
                        role="alert"
                        invisible="status != 'skipped'"
                    >
                        <i class="fa fa-info-circle me-1" title="Info"/>
                        <strong>Skipped</strong> — duplicate or no-op.
                    </div>

                    <div class="oe_title">
                        <label for="display_name" string="Summary" />
                        <h2>
                            <field name="display_name" readonly="1" />
                        </h2>
                    </div>

                    <group>
                        <group string="Operation">
                            <field name="direction"
                                widget="badge"
                                decoration-info="direction == 'inbound'"
                                decoration-warning="direction == 'outbound'"
                            />
                            <field name="operation" />
                            <field name="event_type"
                                invisible="direction != 'outbound' and not event_type"
                            />
                            <field name="status"
                                widget="badge"
                                decoration-success="status == 'success'"
                                decoration-warning="status in ('partial','skipped')"
                                decoration-danger="status == 'failure'"
                                decoration-info="status == 'pending'"
                            />
                            <field name="http_status_code" />
                            <field name="duration_ms" string="Duration (ms)" />
                        </group>
                        <group string="Records">
                            <field name="odoo_model" />
                            <field name="odoo_record_id" />
                            <field name="django_model" />
                            <field name="django_record_id" />
                            <field name="api_key_id" options="{'no_create': True}" />
                            <field name="webhook_retry_id"
                                invisible="not webhook_retry_id"
                                options="{'no_create': True}"
                            />
                            <field name="company_id" options="{'no_create': True}" />
                        </group>
                    </group>

                    <group
                        string="Failure Detail"
                        invisible="status not in ('failure','partial')"
                    >
                        <field
                            name="detail"
                            nolabel="1"
                            widget="text"
                            readonly="1"
                        />
                    </group>

                    <group
                        string="Detail"
                        invisible="status in ('failure','partial') or not detail"
                    >
                        <field
                            name="detail"
                            nolabel="1"
                            widget="text"
                            readonly="1"
                        />
                    </group>

                    <notebook>
                        <page string="Request / Outbound Payload" name="request">
                            <field
                                name="request_data"
                                nolabel="1"
                                widget="text"
                                readonly="1"
                                placeholder="JSON payload (inbound request body or outbound webhook payload)."
                            />
                        </page>
                        <page string="Response / Callback Body" name="response">
                            <field
                                name="response_data"
                                nolabel="1"
                                widget="text"
                                readonly="1"
                                placeholder="JSON response sent to Django, or response received from Django."
                            />
                        </page>
                        <page string="Request Metadata" name="metadata"
                            invisible="direction != 'inbound'"
                        >
                            <group>
                                <field name="remote_ip" />
                                <field name="user_agent" />
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================================================================
         alba.sync.log — List View
         ================================================================ -->
    <record id="view_alba_sync_log_list" model="ir.ui.view">
        <field name="name">alba.sync.log.list</field>
        <field name="model">alba.sync.log</field>
        <field name="arch" type="xml">
            <list
                string="Sync Logs"
                create="false"
                edit="false"
                decoration-success="status == 'success'"
                decoration-warning="status in ('partial','skipped')"
                decoration-danger="status == 'failure'"
                decoration-muted="status == 'pending'"
            >
                <field name="create_date" string="Timestamp" />
                <field name="direction"
                    widget="badge"
                    decoration-info="direction == 'inbound'"
                    decoration-warning="direction == 'outbound'"
                />
                <field name="operation" />
                <field name="event_type" optional="show" />
                <field name="odoo_model" />
                <field name="odoo_record_id" string="Odoo ID" />
                <field name="django_record_id" string="Django ID" optional="show" />
                <field name="status"
                    widget="badge"
                    decoration-success="status == 'success'"
                    decoration-warning="status in ('partial','skipped')"
                    decoration-danger="status == 'failure'"
                    decoration-info="status == 'pending'"
                />
                <field name="http_status_code" string="HTTP" optional="show" />
                <field name="duration_ms" string="ms" optional="show" />
                <field name="api_key_id" string="API Key" optional="hide" />
                <field name="remote_ip" optional="hide" />
                <field name="company_id" optional="hide" />
                <field name="detail" optional="hide" />
            </list>
        </field>
    </record>

    <!-- ================================================================
         alba.sync.log — List View
         ================================================================ -->
    <record id="view_alba_sync_log_list" model="ir.ui.view">
        <field name="name">alba.sync.log.list</field>
        <field name="model">alba.sync.log</field>
        <field name="arch" type="xml">
            <list
                string="Sync Logs"
                create="false"
                edit="false"
                decoration-success="status == 'success'"
                decoration-warning="status in ('partial','skipped')"
                decoration-danger="status == 'failure'"
                decoration-muted="status == 'pending'"
            >
                <field name="create_date" string="Timestamp" />
                <field name="direction"
                    widget="badge"
                    decoration-info="direction == 'inbound'"
                    decoration-warning="direction == 'outbound'"
                />
                <field name="operation" />
                <field name="event_type" optional="show" />
                <field name="odoo_model" />
                <field name="odoo_record_id" string="Odoo ID" />
                <field name="django_record_id" string="Django ID" optional="show" />
                <field name="status"
                    widget="badge"
                    decoration-success="status == 'success'"
                    decoration-warning="status in ('partial','skipped')"
                    decoration-danger="status == 'failure'"
                    decoration-info="status == 'pending'"
                />
                <field name="http_status_code" string="HTTP" optional="show" />
                <field name="duration_ms" string="ms" optional="show" />
                <field name="api_key_id" string="API Key" optional="hide" />
                <field name="remote_ip" optional="hide" />
                <field name="company_id" optional="hide" />
                <field name="detail" optional="hide" />
            </list>
        </field>
    </record>

    <!-- ================================================================
         alba.sync.log — Search View
         ================================================================ -->
    <record id="view_alba_sync_log_search" model="ir.ui.view">
        <field name="name">alba.sync.log.search</field>
        <field name="model">alba.sync.log</field>
        <field name="arch" type="xml">
            <search string="Search Sync Logs">
                <field name="odoo_model" string="Odoo Model" />
                <field name="event_type" string="Event Type" />
                <field name="api_key_id" string="API Key" />
                <field name="odoo_record_id" string="Odoo Record ID" />
                <field name="django_record_id" string="Django Record ID" />
                <separator />
                <filter
                    string="Inbound"
                    name="inbound"
                    domain="[('direction','=','inbound')]"
                />
                <filter
                    string="Outbound"
                    name="outbound"
                    domain="[('direction','=','outbound')]"
                />
                <separator />
                <filter
                    string="Success"
                    name="success"
                    domain="[('status','=','success')]"
                />
                <filter
                    string="Failures"
                    name="failures"
                    domain="[('status','in',['failure','partial'])]"
                />
                <filter
                    string="Skipped"
                    name="skipped"
                    domain="[('status','=','skipped')]"
                />
                <separator />
                <filter
                    string="Today"
                    name="today"
                    domain="[('create_date','&gt;=',(context_today()).strftime('%Y-%m-%d'))]"
                />
                <filter
                    string="Last 7 Days"
                    name="last_7_days"
                    domain="[('create_date','&gt;=',(context_today()-datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"
                />
                <filter
                    string="This Month"
                    name="this_month"
                    domain="[('create_date','&gt;=',(context_today().replace(day=1)).strftime('%Y-%m-%d'))]"
                />
            </search>
        </field>
    </record>

    <!-- ================================================================
         alba.sync.log — Action Window
         ================================================================ -->
    <record id="action_alba_sync_log" model="ir.actions.act_window">
        <field name="name">Sync Logs</field>
        <field name="res_model">alba.sync.log</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_alba_sync_log_list"/>
        <field name="search_view_id" ref="view_alba_sync_log_search" />
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No sync log entries yet.
            </p>
            <p>
                Every Django ↔ Odoo synchronisation operation is recorded here —
                both inbound (Django calling Odoo REST endpoints) and outbound
                (Odoo firing webhooks to Django).  Use the filters to isolate
                failures, track specific records, or review activity by direction
                or time window.
            </p>
        </field>
    </record>

    <!-- Failures-only shortcut action -->
    <record id="action_alba_sync_log_failures" model="ir.actions.act_window">
        <field name="name">Sync Failures</field>
        <field name="res_model">alba.sync.log</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_alba_sync_log_list"/>
        <field name="domain">[('status','in',['failure','partial'])]</field>
        <field name="search_view_id" ref="view_alba_sync_log_search" />
        <field name="context">{'search_default_failures': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No sync failures — everything is running smoothly!
            </p>
        </field>
    </record>

</data>
</odoo>
